<odoo>
    <record id="view_zegal_approval_request_tree" model="ir.ui.view">
        <field name="name">zegal.approval.request.tree</field>
        <field name="model">zegal.approval.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="request_type"/>
                <field name="department_code"/>
                <field name="approval_scope"/>
                <field name="state"/>
                <field name="sale_order_id"/>
                <field name="purchase_order_id"/>
                <field name="project_id"/>
                <field name="document_id"/>
                <field name="amount_total"/>
                <field name="approver_id"/>
            </list>
        </field>
    </record>
    <record id="view_zegal_approval_request_form" model="ir.ui.view">
        <field name="name">zegal.approval.request.form</field>
        <field name="model">zegal.approval.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'to_approve'"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-secondary" invisible="state not in ('draft','to_approve')"/>
                    <button name="action_reset" type="object" string="Reset" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,to_approve,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="request_type"/>
                        <field name="department_code"/>
                        <field name="approval_scope"/>
                        <field name="matrix_id"/>
                        <field name="user_id"/>
                        <field name="approver_id"/>
                        <field name="next_approver_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="sale_order_id"/>
                        <field name="purchase_order_id"/>
                        <field name="project_id"/>
                        <field name="document_id"/>
                    </group>
                    <group>
                        <field name="amount_total"/>
                        <field name="margin_percent"/>
                        <field name="partner_id"/>
                        <field name="source_ref"/>
                        <field name="company_id"/>
                    </group>
                    <group string="Checklist">
                        <field name="checklist_scope"/>
                        <field name="checklist_margin"/>
                        <field name="checklist_budget"/>
                        <field name="checklist_timeline"/>
                        <field name="checklist_attachment"/>
                        <field name="checklist_terms"/>
                        <field name="checklist_handover"/>
                        <field name="checklist_required_ok" readonly="1"/>
                    </group>
                    <div class="alert alert-warning" invisible="checklist_required_ok">
                        Checklist is not complete yet.
                    </div>
                    <notebook>
                        <page string="Notes">
                            <field name="note"/>
                        <field name="approval_message" readonly="1"/>
                        </page>
                        <page string="Audit Trail">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="action"/>
                                    <field name="state_from"/>
                                    <field name="state_to"/>
                                    <field name="user_id"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Approval Steps">
                            <field name="step_ids" readonly="1">
                                <list>
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="approver_id"/>
                                    <field name="state"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_zegal_approval_request" model="ir.actions.act_window">
        <field name="name">Approval Requests</field>
        <field name="res_model">zegal.approval.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
