<odoo>
    <record id="view_zegal_purchase_request_list" model="ir.ui.view">
        <field name="name">zegal.purchase.request.list</field>
        <field name="model">zegal.purchase.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="request_type"/>
                <field name="project_id"/>
                <field name="vendor_id"/>
                <field name="need_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="view_zegal_purchase_request_form" model="ir.ui.view">
        <field name="name">zegal.purchase.request.form</field>
        <field name="model">zegal.purchase.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'to_approve'"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-secondary" invisible="state not in ('draft','to_approve')"/>
                    <button name="action_create_rfq" type="object" string="Create RFQ" class="btn-secondary"/>
                    <button name="action_create_po" type="object" string="Create PO" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,to_approve,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="request_type"/>
                        <field name="project_id"/>
                        <field name="vendor_id"/>
                        <field name="need_date"/>
                        <field name="request_date"/>
                        <field name="budget_total" readonly="1"/>
                        <field name="lead_time_days" readonly="1"/>
                        <field name="company_id"/>
                        <field name="approval_request_id" readonly="1"/>
                        <field name="rfq_count" readonly="1"/>
                        <field name="po_count" readonly="1"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="budget_amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_zegal_purchase_request" model="ir.actions.act_window">
        <field name="name">Purchase Requests</field>
        <field name="res_model">zegal.purchase.request</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
