<odoo>
    <record id="view_sale_order_form_zegal_flow" model="ir.ui.view">
        <field name="name">sale.order.form.zegal.flow</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Zegal Flow">
                    <field name="zegal_quote_type"/>
                    <field name="zegal_quote_revision"/>
                    <field name="zegal_margin_percent"/>
                    <field name="zegal_approval_request_id"/>
                    <field name="zegal_approval_state" readonly="1"/>
                </group>
                <group string="Approval Checklist">
                    <field name="checklist_scope"/>
                    <field name="checklist_margin"/>
                    <field name="checklist_budget"/>
                    <field name="checklist_timeline"/>
                    <field name="checklist_attachment"/>
                    <field name="checklist_terms"/>
                    <field name="checklist_handover"/>
                </group>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_request_zegal_approval" type="object" string="Request Approval" class="btn-primary"/>
                <button name="action_create_project_document" type="object" string="Create Project Dossier" class="btn-secondary"/>
            </xpath>
        </field>
    </record>
</odoo>
