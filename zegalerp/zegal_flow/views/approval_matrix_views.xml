<odoo>
    <record id="view_zegal_approval_matrix_tree" model="ir.ui.view">
        <field name="name">zegal.approval.matrix.tree</field>
        <field name="model">zegal.approval.matrix</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="request_type"/>
                <field name="department_code"/>
                <field name="approval_scope"/>
                <field name="min_amount"/>
                <field name="max_amount"/>
                <field name="min_margin"/>
                <field name="approver_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_zegal_approval_matrix_form" model="ir.ui.view">
        <field name="name">zegal.approval.matrix.form</field>
        <field name="model">zegal.approval.matrix</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="request_type"/>
                        <field name="department_code"/>
                        <field name="approval_scope"/>
                        <field name="approver_id"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="min_amount"/>
                        <field name="max_amount"/>
                        <field name="min_margin"/>
                        <field name="company_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_zegal_approval_matrix" model="ir.actions.act_window">
        <field name="name">Approval Matrix</field>
        <field name="res_model">zegal.approval.matrix</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
