<odoo>
    <record id="view_order_form_inherit_att_contract" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.att.contract</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//list//field[@name='product_template_id']" position="attributes">
                <attribute name="string">Dịch vụ</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="att_contract_id" readonly="1"/>
                <field name="att_appendix_id" readonly="1"/>
                <field name="att_quotation_request_id" readonly="1"/>
            </xpath>

            <xpath expr="//field[@name='order_line']//list//field[@name='name']" position="after">
                <field name="att_appendix_line_id" optional="hide"/>
                <field name="pickup_location" optional="show"/>
                <field name="delivery_location" optional="show"/>
                <field name="route_detail" optional="hide"/>
                <field name="vehicle_id" optional="show"/>
                <field name="transport_mode_id" optional="show"/>
                <field name="cargo_description" optional="hide"/>
            </xpath>

        </field>
    </record>


    <record id="view_order_tree_inherit_att_contract" model="ir.ui.view">
        <field name="name">sale.order.list.inherit.att.contract</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="att_contract_id" optional="show"/>
                <field name="att_appendix_id" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>