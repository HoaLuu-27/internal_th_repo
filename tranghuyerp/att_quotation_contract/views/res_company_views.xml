<odoo>
    <record id="view_company_form_inherit_att_report_assets" model="ir.ui.view">
        <field name="name">res.company.form.inherit.att.report.assets</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Mẫu in Trang Huy">
                    <group>
                        <group string="Header / Footer">
                            <field name="report_header_logo" widget="image"/>
                            <field name="report_esg_logo" widget="image"/>
                            <field name="report_footer_image" widget="image"/>
                        </group>
                        <group string="Chữ ký / Con dấu">
                            <field name="report_stamp_image" widget="image"/>
                            <field name="report_signature_image" widget="image"/>
                            <field name="report_signer_title"/>
                            <field name="report_signer_name"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>