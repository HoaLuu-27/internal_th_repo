<odoo>

    <!-- Replace menu Quotations gốc của Sales -->
    <record id="sale.menu_sale_quotations" model="ir.ui.menu">
        <field name="name">Báo giá</field>
        <field name="action" ref="action_att_sale_quotation_request"/>
        <field name="sequence">1</field>
    </record>

    <!-- Thêm Hợp đồng / Phụ lục vào Sales > Orders -->
    <menuitem id="menu_att_sale_contract"
              name="Hợp đồng"
              parent="sale.sale_order_menu"
              action="action_att_sale_contract"
              sequence="11"/>

    <menuitem id="menu_att_sale_appendix"
              name="Phụ lục"
              parent="sale.sale_order_menu"
              action="action_att_sale_contract_appendix"
              sequence="12"/>


    <!-- Replace menu RFQ gốc của Purchase -->
    <record id="purchase.menu_purchase_rfq" model="ir.ui.menu">
        <field name="name">Báo giá NCC</field>
        <field name="action" ref="action_att_purchase_quotation_request"/>
        <field name="sequence">1</field>
    </record>

    <!-- Thêm Hợp đồng / Phụ lục vào Purchase -->
    <menuitem id="menu_att_purchase_contract"
              name="Hợp đồng NCC"
              parent="purchase.menu_procurement_management"
              action="action_att_purchase_contract"
              sequence="11"/>

    <menuitem id="menu_att_purchase_appendix"
              name="Phụ lục NCC"
              parent="purchase.menu_procurement_management"
              action="action_att_purchase_contract_appendix"
              sequence="12"/>
    <!-- Configuration Sale -->
    <menuitem id="menu_att_sale_contract_clause"
              name="Điều khoản hợp đồng"
              parent="sale.menu_sale_config"
              action="action_att_sale_contract_clause"
              sequence="20"/>

    <!-- Configuration Purchase -->
    <menuitem id="menu_att_purchase_contract_clause"
              name="Điều khoản hợp đồng"
              parent="purchase.menu_purchase_config"
              action="action_att_purchase_contract_clause"
              sequence="20"/>
</odoo>