    <record id="action_att_sale_contract" model="ir.actions.act_window">
        <field name="name">Hợp đồng</field>
        <field name="res_model">att.contract</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('contract_type','=','sale')]</field>
        <field name="context">{'default_contract_type': 'sale'}</field>
        <field name="search_view_id" ref="view_att_contract_search"/>
    </record>

    <record id="action_att_purchase_contract" model="ir.actions.act_window">
        <field name="name">Hợp đồng NCC</field>
        <field name="res_model">att.contract</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('contract_type','=','purchase')]</field>
        <field name="context">{'default_contract_type': 'purchase'}</field>
        <field name="search_view_id" ref="view_att_contract_search"/>
    </record>

