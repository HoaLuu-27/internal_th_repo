 <odoo>
    <record id="view_att_contract_list" model="ir.ui.view">
        <field name="name">att.contract.list</field>
        <field name="model">att.contract</field>
        <field name="arch" type="xml">
            <list string="Hợp đồng">
                <field name="name"/>
                <field name="contract_type"/>
                <field name="partner_id"/>
<!--                <field name="date_signed"/>-->
                <field name="effective_date"/>
                <field name="expired_date"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>


    <record id="view_att_contract_form" model="ir.ui.view">
        <field name="name">att.contract.form</field>
        <field name="model">att.contract</field>
        <field name="arch" type="xml">
            <form string="Hợp đồng">

                <header>
                    <button name="action_send_draft_to_partner"
                            string="Gửi bản nháp"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'draft'"/>
                    <button name="action_request_confirm"
                            string="Yêu cầu xác nhận"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            groups="base.group_user"/>

                    <button name="action_validate"
                            string="Xác nhận hiệu lực"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'confirm_requested'"
                            groups="att_quotation_contract.group_att_contract_ceo"
                    />

                    <button name="action_request_liquidation"
                            string="Yêu cầu thanh lý"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'running' or not liquidation_reason_id"/>

                    <button name="action_approve_liquidation"
                            string="Duyệt thanh lý"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'liquidation_requested'"
                            groups="att_quotation_contract.group_att_contract_ceo"
                    />

                    <button name="action_cancel"
                            string="Hủy"
                            type="object"
                            invisible="state != 'draft'"/>

                    <button name="action_reset_to_draft"
                            string="Đưa về nháp"
                            type="object"
                            invisible="state != 'cancelled'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,running,liquidation_requested,liquidated,cancelled"/>
                </header>

                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_appendix"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="state in ('draft', 'confirm_requested')">
                            <field name="appendix_count"
                                   widget="statinfo"
                                   string="Phụ lục"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Thông tin chung">
                            <field name="contract_type"/>
                            <field name="partner_id"/>
                            <field name="source_quotation_id"/>
                            <field name="sale_order_id"
                                   invisible="contract_type != 'purchase'"/>
                            <field name="user_id"/>
                            <field name="company_id"/>
                            <field name="currency_id"/>
                        </group>

                        <group string="Hiệu lực hợp đồng">
<!--                            <field name="date_signed"/>-->
                            <field name="effective_date"/>
                            <field name="expired_date"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Thông tin đối tác">
                            <group>
                                <group>
                                    <field name="partner_address"/>
                                    <field name="partner_phone"/>
                                    <field name="partner_email"/>
                                    <field name="partner_tax_code"/>
                                </group>
                                <group>
                                    <field name="partner_bank_account"/>
                                    <field name="partner_representative"/>
                                    <field name="partner_position"/>
                                </group>
                            </group>
                        </page>

                        <page string="Thanh toán">
                            <group>
                                <group>
                                    <field name="payment_term_id"/>
                                    <field name="payment_method"/>
                                    <field name="payment_deadline_days"/>
                                </group>
                            </group>

                            <group>
                                <field name="payment_document_note"/>
                                <field name="payment_note"/>
                                <field name="late_payment_penalty_note"/>
                                <field name="waiting_fee_note"/>
                            </group>
                        </page>

                        <page string="Điều khoản">
                            <field name="term_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="clause_id"
                                           domain="[('clause_type', 'in', [parent.contract_type, 'both'])]"
                                           options="{'no_create': True}"/>
                                    <field name="is_fixed" readonly="1"/>
                                    <field name="title" readonly="is_fixed"/>
                                    <field name="content" widget="html" readonly="is_fixed" optional="show"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Thanh lý" invisible="state not in ('running', 'liquidation_requested', 'liquidated')">
                            <group>
                                <field name="liquidation_reason_id"
                                       options="{'no_create': False}"
                                       readonly="state in ('liquidation_requested', 'liquidated')"/>
                                <field name="liquidation_note"
                                       readonly="state in ('liquidation_requested', 'liquidated')"/>
                                <field name="liquidation_requested_by" readonly="1" invisible="not liquidation_requested_by"/>
                                <field name="liquidation_requested_date" readonly="1" invisible="not liquidation_requested_date"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>

