<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree -->
    <record id="view_att_transport_mode_tree" model="ir.ui.view">
        <field name="name">att.transport.mode.list</field>
        <field name="model">att.transport.mode</field>
        <field name="arch" type="xml">
            <list string="Hình thức vận chuyển" multi_edit="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_att_transport_mode_form" model="ir.ui.view">
        <field name="name">att.transport.mode.form</field>
        <field name="model">att.transport.mode</field>
        <field name="arch" type="xml">
            <form string="Hình thức vận chuyển">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_att_transport_mode" model="ir.actions.act_window">
        <field name="name">Hình thức vận chuyển</field>
        <field name="res_model">att.transport.mode</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_att_transport_mode"
        name="Hình thức vận chuyển"
        parent="purchase.menu_purchase_config"
        action="action_att_transport_mode"
        sequence="80"/>

</odoo>