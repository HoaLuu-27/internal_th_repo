    <record id="action_att_sale_contract_appendix" model="ir.actions.act_window">
        <field name="name">Phụ lục</field>
        <field name="res_model">att.contract.appendix</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('appendix_type','=','sale')]</field>
        <field name="context">{'default_appendix_type': 'sale'}</field>
        <field name="search_view_id" ref="view_att_contract_appendix_search"/>
    </record>

