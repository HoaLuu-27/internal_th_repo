<odoo>
    <record id="view_att_contract_clause_list" model="ir.ui.view">
        <field name="name">att.contract.clause.list</field>
        <field name="model">att.contract.clause</field>
        <field name="arch" type="xml">
            <list string="Điều khoản hợp đồng">
                <field name="sequence" widget="handle"/>
                <field name="title"/>
                <field name="clause_type"/>
                <field name="is_fixed"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_att_contract_clause_form" model="ir.ui.view">
        <field name="name">att.contract.clause.form</field>
        <field name="model">att.contract.clause</field>
        <field name="arch" type="xml">
            <form string="Điều khoản hợp đồng">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="clause_type"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="is_fixed"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Nội dung">
                        <field name="title" nolabel="1" placeholder="Điều X: TIÊU ĐỀ ĐIỀU KHOẢN"/>
                        <field name="content" nolabel="1" widget="html"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_att_sale_contract_clause" model="ir.actions.act_window">
        <field name="name">Điều khoản hợp đồng bán</field>
        <field name="res_model">att.contract.clause</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('clause_type', 'in', ['sale', 'both'])]</field>
        <field name="context">{'default_clause_type': 'sale'}</field>
    </record>

    <record id="action_att_purchase_contract_clause" model="ir.actions.act_window">
        <field name="name">Điều khoản hợp đồng mua</field>
        <field name="res_model">att.contract.clause</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('clause_type', 'in', ['purchase', 'both'])]</field>
        <field name="context">{'default_clause_type': 'purchase'}</field>
    </record>
</odoo>