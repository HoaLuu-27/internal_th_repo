<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_view_form_meinvoice" model="ir.ui.view">
        <field name="name">account.move.form.meinvoice</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Thêm buttons vào header, chỉ hiện với out_invoice -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <!-- Smart button: xem log -->
                <button name="%(att_connector_meinvoice.action_meinvoice_log)d"
                        type="action"
                        
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="move_type != 'out_invoice'">
                    <div class="o_stat_info">
                        <span class="o_stat_text">MeInvoice</span>
                        <span class="o_stat_text">
                            <field name="meinvoice_state"/>
                        </span>
                    </div>
                </button>
            </xpath>

            <!-- Thêm buttons hành động vào statusbar -->
            <xpath expr="//div[@name='button_box']" position="after">
                <div name="meinvoice_buttons"
                     invisible="move_type != 'out_invoice'">
                    <button string="Xem trước HĐ"
                            name="action_meinvoice_preview"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'posted'"/>
                    <button string="Phát hành MeInvoice"
                            name="action_meinvoice_send"
                            type="object"
                            class="btn-primary"
                            invisible="not meinvoice_can_send"/>
                    <button string="Cập nhật trạng thái"
                            name="action_meinvoice_refresh_status"
                            type="object"
                            class="btn-secondary"
                            invisible="meinvoice_state != 'issued'"/>
                    <button string="Gửi email HĐ"
                            name="action_meinvoice_send_email"
                            type="object"
                            class="btn-secondary"
                            invisible="meinvoice_state != 'issued'"/>
                </div>
            </xpath>

            <!-- Tab MeInvoice trong notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="MeInvoice E-Invoice"
                      name="meinvoice_tab"
                      invisible="move_type != 'out_invoice'">
                    <group>
                        <group string="Trạng thái">
                            <field name="meinvoice_state"/>
                            <field name="meinvoice_ref_id"/>
                            <field name="meinvoice_transaction_id"/>
                            <field name="meinvoice_inv_no"/>
                            <field name="meinvoice_inv_date"/>
                        </group>
                        <group string="Lỗi"
                               invisible="meinvoice_state != 'error'">
                            <field name="meinvoice_error_msg" nolabel="1"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>