<odoo>
    <data noupdate="1">
        <!-- Hình thức vận chuyển (Loại hình dịch vụ) + liên kết loại xe (att_fleet_extend) -->
        <record id="tmode_duong_bo" model="att.transport.mode">
            <field name="name">Đường bộ</field>
            <field name="sequence">10</field>
            <field name="website_short_description">Chỉ vận chuyển bằng đường bộ</field>
            <field name="vehicle_type_ids" eval="[(6, 0, [
                ref('att_fleet_extend.vtype_xe_may'), ref('att_fleet_extend.vtype_van_5ta'),
                ref('att_fleet_extend.vtype_ban_tai'), ref('att_fleet_extend.vtype_van_1tan'),
                ref('att_fleet_extend.vtype_tai_5ta')])]"/>
        </record>
        <record id="tmode_da_phuong_thuc" model="att.transport.mode">
            <field name="name">Đa phương thức</field>
            <field name="sequence">20</field>
            <field name="website_short_description">Kết hợp đường bộ - thuỷ/sắt/hàng không. Báo giá thể hiện 1 hình thức nhưng chi phí tách theo từng chặng.</field>
            <field name="vehicle_type_ids" eval="[(6, 0, [
                ref('att_fleet_extend.vtype_van_5ta'), ref('att_fleet_extend.vtype_ban_tai'),
                ref('att_fleet_extend.vtype_van_1tan'), ref('att_fleet_extend.vtype_tai_5ta')])]"/>
        </record>
        <record id="tmode_duong_bien" model="att.transport.mode">
            <field name="name">Đường biển</field><field name="sequence">30</field>
        </record>
        <record id="tmode_duong_hang_khong" model="att.transport.mode">
            <field name="name">Đường hàng không</field><field name="sequence">40</field>
        </record>
        <record id="tmode_duong_sat" model="att.transport.mode">
            <field name="name">Đường sắt</field><field name="sequence">50</field>
        </record>
        <record id="tmode_duong_song" model="att.transport.mode">
            <field name="name">Đường sông</field><field name="sequence">60</field>
        </record>
        <record id="tmode_dv_hai_quan" model="att.transport.mode">
            <field name="name">Dịch vụ hải quan</field><field name="sequence">70</field>
            <field name="website_short_description">Khách chỉ thuê Trang Huy khai báo hải quan 1 đầu hoặc 2 đầu, không thuê vận chuyển.</field>
        </record>
        <record id="tmode_dv_cau" model="att.transport.mode">
            <field name="name">Dịch vụ cầu</field><field name="sequence">80</field>
            <field name="website_short_description">Thuê cẩu tại chỗ hoặc vừa cẩu vừa vận chuyển; ghi chú chi tiết làm cơ sở tính cước.</field>
        </record>
        <record id="tmode_thue_kho" model="att.transport.mode">
            <field name="name">Thuê kho</field><field name="sequence">90</field>
            <field name="website_short_description">Khách có nhu cầu thuê kho.</field>
        </record>
        <record id="tmode_cpn" model="att.transport.mode">
            <field name="name">CPN</field><field name="sequence">100</field>
            <field name="vehicle_type_ids" eval="[(6, 0, [
                ref('att_fleet_extend.vtype_xe_may'), ref('att_fleet_extend.vtype_van_5ta')])]"/>
        </record>
        <record id="tmode_hang_ghep" model="att.transport.mode">
            <field name="name">Hàng ghép</field><field name="sequence">110</field>
            <field name="vehicle_type_ids" eval="[(6, 0, [
                ref('att_fleet_extend.vtype_van_5ta'), ref('att_fleet_extend.vtype_ban_tai'),
                ref('att_fleet_extend.vtype_van_1tan'), ref('att_fleet_extend.vtype_tai_5ta')])]"/>
        </record>
    </data>
</odoo>
