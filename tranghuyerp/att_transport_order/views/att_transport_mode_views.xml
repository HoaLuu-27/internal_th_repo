<odoo>
    <record id="view_att_transport_mode_list" model="ir.ui.view">
        <field name="name">att.transport.mode.list</field>
        <field name="model">att.transport.mode</field>
        <field name="arch" type="xml">
            <list string="Hình thức vận chuyển">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="website_published"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_att_transport_mode_form" model="ir.ui.view">
        <field name="name">att.transport.mode.form</field>
        <field name="model">att.transport.mode</field>
        <field name="arch" type="xml">
            <form string="Hình thức vận chuyển">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="website_published"/>
                            <field name="default_product_id"/>
                        </group>
                        <group>
                            <field name="image" widget="image"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Loại xe áp dụng">
                            <field name="vehicle_type_ids" widget="many2many_tags"
                                   options="{'no_create_edit': True}"/>
                        </page>
                        <page string="Nội dung website">
                            <field name="website_short_description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_att_transport_mode" model="ir.actions.act_window">
        <field name="name">Hình thức vận chuyển</field>
        <field name="res_model">att.transport.mode</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
