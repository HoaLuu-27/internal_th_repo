<odoo>
    <record id="view_th_transport_route_list" model="ir.ui.view">
        <field name="name">att.transport.route.list</field>
        <field name="model">att.transport.route</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="origin_name"/>
                <field name="destination_name"/>
                <field name="distance_km"/>
                <field name="reverse_route_id" optional="show"/>
                <field name="active_to_count"/>
            </list>
        </field>
    </record>

    <record id="view_th_transport_route_form" model="ir.ui.view">
        <field name="name">att.transport.route.form</field>
        <field name="model">att.transport.route</field>
        <field name="arch" type="xml">
            <form string="Tuyến đường">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_transport_orders" type="object"
                                class="oe_stat_button" icon="fa-truck">
                            <field name="active_to_count" widget="statinfo" string="Lệnh đang chạy"/>
                        </button>
                    </div>
                    <div class="oe_title"><h1><field name="name" placeholder="Hà Nội – Hải Phòng"/></h1></div>
                    <group>
                        <group string="Hai đầu tuyến">
                            <field name="origin_name"/>
                            <field name="destination_name"/>
                            <field name="distance_km"/>
                            <field name="eta_minutes"/>
                            <field name="reverse_route_id"/>
                        </group>
                        <group string="Tọa độ GPS (bản đồ nhiệt)">
                            <field name="origin_lat"/>
                            <field name="origin_lng"/>
                            <field name="destination_lat"/>
                            <field name="destination_lng"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="NCC chuyên tuyến">
                            <field name="vendor_route_ids">
                                <list editable="bottom">
                                    <field name="priority"/>
                                    <field name="vendor_id"/>
                                    <field name="vehicle_type_id"/>
                                    <field name="price_per_trip"/>
                                    <field name="active" widget="boolean_toggle"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_th_transport_route" model="ir.actions.act_window">
        <field name="name">Tuyến đường</field>
        <field name="res_model">att.transport.route</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_th_vendor_route_rule" model="ir.actions.act_window">
        <field name="name">NCC chuyên tuyến</field>
        <field name="res_model">att.vendor.route.rule</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="view_th_vendor_route_rule_list" model="ir.ui.view">
        <field name="name">att.vendor.route.rule.list</field>
        <field name="model">att.vendor.route.rule</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="route_id"/>
                <field name="priority"/>
                <field name="vendor_id"/>
                <field name="vehicle_type_id"/>
                <field name="price_per_trip"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>
    <record id="action_th_commodity" model="ir.actions.act_window">
        <field name="name">Loại hàng hóa</field>
        <field name="res_model">att.commodity</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
