<odoo>
    <record id="view_th_cost_type_list" model="ir.ui.view">
        <field name="name">att.transport.cost.type.list</field>
        <field name="model">att.transport.cost.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="paid_by"/>
                <field name="expense_type"/>
                <field name="product_id"/>
                <field name="requires_approval" widget="boolean_toggle"/>
                <field name="approval_threshold"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_th_cost_line_list" model="ir.ui.view">
        <field name="name">att.transport.cost.line.list</field>
        <field name="model">att.transport.cost.line</field>
        <field name="arch" type="xml">
            <list decoration-danger="needs_approval and state == 'pending'"
                  decoration-success="state == 'pushed'">
                <field name="date"/>
                <field name="transport_order_id"/>
                <field name="cost_type_id"/>
                <field name="description" optional="show"/>
                <field name="amount" sum="Tổng"/>
                <field name="paid_by"/>
                <field name="needs_approval" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'pending' and needs_approval"
                       decoration-info="state == 'approved'"
                       decoration-success="state == 'pushed'"/>
                <button name="action_approve" string="Duyệt" type="object" icon="fa-check"
                        invisible="state != 'pending' or not needs_approval"
                        groups="sales_team.group_sale_manager"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_th_cost_line_search" model="ir.ui.view">
        <field name="name">att.transport.cost.line.search</field>
        <field name="model">att.transport.cost.line</field>
        <field name="arch" type="xml">
            <search>
                <field name="transport_order_id"/>
                <field name="cost_type_id"/>
                <filter name="pending" string="Chờ phê duyệt"
                        domain="[('state', '=', 'pending'), ('needs_approval', '=', True)]"/>
                <filter name="approved" string="Đã duyệt" domain="[('state', '=', 'approved')]"/>
                <filter name="pushed" string="Đã xử lý" domain="[('state', '=', 'pushed')]"/>
                <group name="groupby">
                    <filter name="group_to" string="Lệnh VC" context="{'group_by': 'transport_order_id'}"/>
                    <filter name="group_type" string="Loại chi phí" context="{'group_by': 'cost_type_id'}"/>
                    <filter name="group_paid_by" string="Bên chịu" context="{'group_by': 'paid_by'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_th_cost_type" model="ir.actions.act_window">
        <field name="name">Loại chi phí</field>
        <field name="res_model">att.transport.cost.type</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_th_cost_line_pending" model="ir.actions.act_window">
        <field name="name">Chi phí chờ phê duyệt</field>
        <field name="res_model">att.transport.cost.line</field>
        <field name="view_mode">list</field>
        <field name="domain">[('state', '=', 'pending'), ('needs_approval', '=', True)]</field>
    </record>
    <record id="action_th_cost_line_all" model="ir.actions.act_window">
        <field name="name">Chi phí phát sinh</field>
        <field name="res_model">att.transport.cost.line</field>
        <field name="view_mode">list</field>
        <field name="context">{'search_default_group_to': 1}</field>
    </record>
</odoo>
