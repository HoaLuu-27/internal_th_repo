<odoo>
    <record id="view_vietmap_test_wizard_form" model="ir.ui.view">
        <field name="name">att.vietmap.test.wizard.form</field>
        <field name="model">att.vietmap.test.wizard</field>
        <field name="arch" type="xml">
            <form string="Test nhanh VietMap API">
                <group>
                    <field name="query_text" placeholder="VD: 128 Phạm Văn Đồng"/>
                    <field name="ref_id" placeholder="Dán ref_id để test Place Detail"/>
                </group>
                <footer>
                    <button name="action_test_search" string="Test Search Address"
                            type="object" class="btn-primary"/>
                    <button name="action_test_place_detail" string="Test Place Detail"
                            type="object" class="btn-secondary"/>
                </footer>
                <field name="result_json" widget="text" readonly="1"/>
            </form>
        </field>
    </record>

    <record id="action_vietmap_test_wizard" model="ir.actions.act_window">
        <field name="name">Test nhanh VietMap</field>
        <field name="res_model">att.vietmap.test.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>