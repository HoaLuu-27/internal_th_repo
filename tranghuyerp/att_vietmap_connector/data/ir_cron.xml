<odoo>
    <record id="ir_cron_cleanup_address_suggestion" model="ir.cron">
        <field name="name">VietMap: Dọn gợi ý địa chỉ tạm</field>
        <field name="model_id" ref="model_att_address_suggestion"/>
        <field name="state">code</field>
        <field name="code">model._cron_cleanup_old_suggestions()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=23, minute=30, second=0)"/>
        <field name="active">True</field>
    </record>
</odoo>
