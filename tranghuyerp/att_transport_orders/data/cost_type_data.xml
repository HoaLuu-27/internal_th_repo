<odoo>
    <data noupdate="1">
        <record id="product_cost_bot" model="product.product">
            <field name="name">Phí BOT</field><field name="type">service</field>
            <field name="sale_ok" eval="True"/><field name="purchase_ok" eval="True"/>
        </record>
        <record id="product_cost_cau_ho" model="product.product">
            <field name="name">Chi phí cẩu hộ</field><field name="type">service</field>
            <field name="sale_ok" eval="True"/><field name="purchase_ok" eval="True"/>
        </record>
        <record id="product_cost_phi_cang" model="product.product">
            <field name="name">Phí cảng / bến bãi</field><field name="type">service</field>
            <field name="sale_ok" eval="True"/><field name="purchase_ok" eval="True"/>
        </record>
        <record id="product_cost_boc_xep" model="product.product">
            <field name="name">Phí bốc xếp hàng hóa</field><field name="type">service</field>
            <field name="sale_ok" eval="True"/><field name="purchase_ok" eval="True"/>
        </record>
        <record id="product_cost_sua_xe" model="product.product">
            <field name="name">Sửa xe đột xuất</field><field name="type">service</field>
            <field name="sale_ok" eval="False"/><field name="purchase_ok" eval="True"/>
        </record>

        <record id="cost_type_bot" model="att.transport.cost.type">
            <field name="name">BOT</field><field name="paid_by">customer</field>
            <field name="expense_type">so_line</field><field name="product_id" ref="product_cost_bot"/>
            <field name="is_toll" eval="True"/>
            <field name="default_description">Phí BOT phát sinh trên tuyến</field>
        </record>
        <record id="cost_type_cau_ho" model="att.transport.cost.type">
            <field name="name">Cẩu hộ</field><field name="paid_by">customer</field>
            <field name="expense_type">so_line</field><field name="product_id" ref="product_cost_cau_ho"/>
            <field name="requires_approval" eval="True"/>
            <field name="default_description">Chi phí cẩu hộ tại điểm bốc/hạ</field>
        </record>
        <record id="cost_type_phi_cang" model="att.transport.cost.type">
            <field name="name">Phí cảng</field><field name="paid_by">customer</field>
            <field name="expense_type">so_line</field><field name="product_id" ref="product_cost_phi_cang"/>
            <field name="default_description">Phí cảng / lưu bãi</field>
        </record>
        <record id="cost_type_boc_xep" model="att.transport.cost.type">
            <field name="name">Bốc xếp</field><field name="paid_by">customer</field>
            <field name="expense_type">so_line</field><field name="product_id" ref="product_cost_boc_xep"/>
            <field name="default_description">Phí bốc xếp hai đầu</field>
        </record>
        <record id="cost_type_duong_cam" model="att.transport.cost.type">
            <field name="name">Phí đường cấm</field><field name="paid_by">company</field>
            <field name="expense_type">internal</field>
            <field name="default_description">Phí vào đường cấm — TH chịu</field>
        </record>
        <record id="cost_type_sua_xe" model="att.transport.cost.type">
            <field name="name">Sửa xe đột xuất</field><field name="paid_by">company</field>
            <field name="expense_type">vendor_bill</field><field name="product_id" ref="product_cost_sua_xe"/>
            <field name="default_description">Sửa chữa xe đột xuất trên đường</field>
        </record>

        <record id="commodity_normal" model="att.commodity"><field name="name">Hàng thường</field></record>
        <record id="commodity_material" model="att.commodity"><field name="name">Vật tư</field></record>
        <record id="commodity_machine" model="att.commodity"><field name="name">Máy móc</field></record>
        <record id="commodity_oversized" model="att.commodity">
            <field name="name">Hàng quá khổ / siêu trường</field><field name="is_oversized" eval="True"/>
        </record>
    </data>
</odoo>
