<odoo>
    <data noupdate="1">
        <!-- Hình thức vận chuyển = sản phẩm dịch vụ thật (product.product),
             không còn model att.transport.mode riêng. Liên kết loại xe qua
             field vehicle_type_ids (att_fleets_extend). -->
        <record id="product_tmode_duong_bo" model="product.product">
            <field name="name">Đường bộ</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
            <field name="website_short_description">Chỉ vận chuyển bằng đường bộ</field>
            <field name="vehicle_type_ids" eval="[(6, 0, [
                ref('att_fleets_extend.vehicle_type_motorbike'), ref('att_fleets_extend.vehicle_type_van_500kg'),
                ref('att_fleets_extend.vehicle_type_pickup'), ref('att_fleets_extend.vehicle_type_van_1t'),
                ref('att_fleets_extend.vehicle_type_truck_5t')])]"/>
        </record>
        <record id="product_tmode_da_phuong_thuc" model="product.product">
            <field name="name">Đa phương thức</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
            <field name="website_short_description">Kết hợp đường bộ - thuỷ/sắt/hàng không. Báo giá thể hiện 1 hình thức nhưng chi phí tách theo từng chặng.</field>
            <field name="vehicle_type_ids" eval="[(6, 0, [
                ref('att_fleets_extend.vehicle_type_van_500kg'), ref('att_fleets_extend.vehicle_type_pickup'),
                ref('att_fleets_extend.vehicle_type_van_1t'), ref('att_fleets_extend.vehicle_type_truck_5t')])]"/>
        </record>
        <record id="product_tmode_duong_bien" model="product.product">
            <field name="name">Đường biển</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
        </record>
        <record id="product_tmode_duong_hang_khong" model="product.product">
            <field name="name">Đường hàng không</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
        </record>
        <record id="product_tmode_duong_sat" model="product.product">
            <field name="name">Đường sắt</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
        </record>
        <record id="product_tmode_duong_song" model="product.product">
            <field name="name">Đường sông</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
        </record>
        <record id="product_tmode_dv_hai_quan" model="product.product">
            <field name="name">Dịch vụ hải quan</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
            <field name="website_short_description">Khách chỉ thuê Trang Huy khai báo hải quan 1 đầu hoặc 2 đầu, không thuê vận chuyển.</field>
        </record>
        <record id="product_tmode_dv_cau" model="product.product">
            <field name="name">Dịch vụ cầu</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
            <field name="website_short_description">Thuê cẩu tại chỗ hoặc vừa cẩu vừa vận chuyển; ghi chú chi tiết làm cơ sở tính cước.</field>
        </record>
        <record id="product_tmode_thue_kho" model="product.product">
            <field name="name">Thuê kho</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
            <field name="website_short_description">Khách có nhu cầu thuê kho.</field>
        </record>
        <record id="product_tmode_cpn" model="product.product">
            <field name="name">CPN</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
            <field name="vehicle_type_ids" eval="[(6, 0, [
                ref('att_fleets_extend.vehicle_type_motorbike'), ref('att_fleets_extend.vehicle_type_van_500kg')])]"/>
        </record>
        <record id="product_tmode_hang_ghep" model="product.product">
            <field name="name">Hàng ghép</field>
            <field name="type">service</field>
            <field name="sale_ok" eval="True"/>
            <field name="purchase_ok" eval="True"/>
            <field name="vehicle_type_ids" eval="[(6, 0, [
                ref('att_fleets_extend.vehicle_type_van_500kg'), ref('att_fleets_extend.vehicle_type_pickup'),
                ref('att_fleets_extend.vehicle_type_van_1t'), ref('att_fleets_extend.vehicle_type_truck_5t')])]"/>
        </record>
    </data>
</odoo>
