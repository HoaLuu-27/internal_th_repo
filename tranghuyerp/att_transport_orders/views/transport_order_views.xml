<odoo>
    <record id="view_att_transport_order_form" model="ir.ui.view">
        <field name="name">att.transport.order.form</field>
        <field name="model">att.transport.order</field>
        <field name="arch" type="xml">
            <form string="Lệnh vận chuyển">
                <header>
                    <button name="action_confirm" string="Xác nhận lệnh" type="object"
                            class="btn-primary" invisible="state != 'draft'"
                            groups="att_transport_orders.group_th_dispatcher"/>
                    <button name="action_in_transit" string="Bắt đầu vận chuyển" type="object"
                            class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_confirm_source" string="Xác nhận bốc hàng" type="object"
                            class="btn-primary" invisible="state != 'in_transit' or source_confirmed"/>
                    <button name="action_confirm_dest" string="Xác nhận giao hàng" type="object"
                            class="btn-primary"
                            invisible="state != 'in_transit' or not source_confirmed or dest_confirmed"/>
                    <button name="action_done" string="Hoàn thành lệnh" type="object"
                            class="btn-primary" invisible="state != 'in_transit' or not dest_confirmed"
                            groups="att_transport_orders.group_th_dispatcher"/>
                    <button name="action_create_backhaul" string="Tạo chuyến về" type="object"
                            invisible="state not in ('confirmed', 'in_transit') or is_backhaul"
                            groups="att_transport_orders.group_th_dispatcher"/>
                    <button name="action_report_incident" string="Báo sự cố" type="object"
                            class="btn-warning" invisible="state not in ('confirmed', 'in_transit')"/>
                    <button name="action_cancel" string="Huỷ lệnh" type="object"
                            invisible="state in ('done', 'cancelled')"
                            groups="att_transport_orders.group_th_dispatcher"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_transit,done"/>
                </header>
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="not is_backhaul">
                        <b>CHUYẾN VỀ</b> — lệnh chiều ngược, giá reset về 0.
                        Lệnh gốc: <field name="origin_to_id" readonly="1" class="oe_inline"/>
                    </div>
                    <div class="alert alert-danger" role="alert" invisible="not incident_note">
                        <b>SỰ CỐ:</b> <field name="incident_note" readonly="1" class="oe_inline"/>
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="origin_type != 'manual'">
                        <b>Lệnh tạo nhanh</b> — SO nháp đi kèm chưa xác nhận. Cập nhật HĐ/PL sau khi ký.
                    </div>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Nguồn &amp; khách hàng">
                            <field name="origin_type" readonly="state != 'draft'"/>
                            <field name="sale_order_id" readonly="state in ('done', 'cancelled')"
                                   domain="[('partner_id', '=?', partner_id)]"/>
                            <field name="sale_order_line_id" readonly="state in ('done', 'cancelled')"
                                   invisible="not sale_order_id" required="origin_type == 'sale'"/>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="route_id" readonly="state != 'draft'"/>
                            <field name="scheduled_date" readonly="state != 'draft'"/>
                            <field name="is_backhaul" invisible="1"/>
                        </group>
                        <group string="Xe &amp; lái xe">
                            <field name="vehicle_source" readonly="state != 'draft'"/>
                            <field name="vehicle_id" readonly="state in ('in_transit', 'done', 'cancelled')"
                                   invisible="vehicle_source != 'internal'"/>
                            <field name="driver_id" readonly="state in ('in_transit', 'done', 'cancelled')"/>
                            <field name="carrier_id" invisible="vehicle_source != 'external'"
                                   readonly="state in ('done', 'cancelled')"/>
                            <field name="purchase_order_id" invisible="vehicle_source != 'external'"
                                   readonly="state in ('done', 'cancelled')"
                                   domain="[('partner_id', '=?', carrier_id)]"/>
                            <field name="actual_departure"/>
                            <field name="actual_arrival"/>
                        </group>
                        <group string="Hàng hóa">
                            <field name="commodity_id"/>
                            <field name="cargo_weight"/>
                            <field name="cargo_volume"/>
                            <field name="container_no"/>
                            <field name="cargo_description"/>
                        </group>
                        <group string="Giá trị">
                            <field name="base_freight"/>
                            <field name="total_customer_cost"/>
                            <field name="total_th_cost"/>
                            <field name="analytic_account_id" groups="analytic.group_analytic_accounting"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dòng chi phí" name="cost_lines">
                            <field name="cost_line_ids">
                                <list editable="bottom"
                                      decoration-muted="is_confirmed and state == 'pending'"
                                      decoration-danger="needs_approval and state == 'pending'"
                                      decoration-success="state == 'pushed'">
                                    <field name="date"/>
                                    <field name="cost_type_id"/>
                                    <field name="description"/>
                                    <field name="amount" sum="Tổng"/>
                                    <field name="paid_by"/>
                                    <field name="expense_type"/>
                                    <field name="is_confirmed" widget="boolean_toggle"/>
                                    <button name="action_confirm_payer" string="Chốt" type="object"
                                            icon="fa-check" invisible="is_confirmed"/>
                                    <field name="needs_approval" column_invisible="1"/>
                                    <field name="state" widget="badge"
                                           decoration-danger="state == 'pending' and needs_approval"
                                           decoration-success="state == 'pushed'"
                                           decoration-info="state == 'approved'"/>
                                    <button name="action_approve" string="Duyệt" type="object" icon="fa-check"
                                            invisible="state != 'pending' or not needs_approval"
                                            groups="sales_team.group_sale_manager"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Bốc / giao hàng" name="confirmations">
                            <group>
                                <group string="Điểm bốc hàng (source)">
                                    <field name="source_confirmed" readonly="1"/>
                                    <field name="source_confirm_date"/>
                                    <field name="source_confirm_note"
                                           placeholder="Biên bản giao nhận — ảnh đính kèm qua Chatter"/>
                                </group>
                                <group string="Điểm giao hàng (dest)">
                                    <field name="dest_confirmed" readonly="1"/>
                                    <field name="dest_confirm_date"/>
                                    <field name="dest_confirm_note"
                                           placeholder="Biên bản ký nhận — ảnh đính kèm qua Chatter"/>
                                </group>
                            </group>
                            <group>
                                <field name="pnv_number"/>
                                <field name="survey_sent" readonly="1"/>
                            </group>
                        </page>
                        <page string="Sự cố / Huỷ" name="incident">
                            <group>
                                <field name="incident_note"
                                       placeholder="Tai nạn / hỏng xe / giao trễ... — điền rồi bấm nút Báo sự cố"/>
                                <field name="cancel_reason"
                                       placeholder="Bắt buộc điền trước khi Huỷ lệnh"
                                       invisible="state == 'done'"/>
                            </group>
                        </page>
                        <page string="Ghi chú" name="notes">
                            <field name="note" placeholder="Ghi chú nội bộ cho điều vận..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_att_transport_order_list" model="ir.ui.view">
        <field name="name">att.transport.order.list</field>
        <field name="model">att.transport.order</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'confirmed'" decoration-success="state == 'in_transit'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="scheduled_date"/>
                <field name="partner_id"/>
                <field name="route_id"/>
                <field name="vehicle_id" optional="show"/>
                <field name="driver_id" optional="show"/>
                <field name="sale_order_id" optional="show"/>
                <field name="sale_order_line_id" optional="hide"/>
                <field name="base_freight" optional="hide" sum="Tổng cước"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'confirmed'"
                       decoration-success="state == 'in_transit'"
                       decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_att_transport_order_search" model="ir.ui.view">
        <field name="name">att.transport.order.search</field>
        <field name="model">att.transport.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="route_id"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <filter name="draft" string="Nháp" domain="[('state', '=', 'draft')]"/>
                <filter name="confirmed" string="Đã xác nhận" domain="[('state', '=', 'confirmed')]"/>
                <filter name="in_transit" string="Đang vận chuyển" domain="[('state', '=', 'in_transit')]"/>
                <filter name="done" string="Hoàn thành" domain="[('state', '=', 'done')]"/>
                <filter name="cancelled" string="Đã huỷ" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="backhaul" string="Chuyến về" domain="[('is_backhaul', '=', True)]"/>
                <filter name="incident" string="Có sự cố" domain="[('incident_note', '!=', False)]"/>
                <filter name="no_vehicle" string="Chưa phân xe"
                        domain="[('vehicle_id', '=', False), ('state', 'in', ('draft', 'confirmed'))]"/>
                <filter name="external" string="Thuê ngoài" domain="[('vehicle_source', '=', 'external')]"/>
                <group name="groupby">
                    <filter name="group_state" string="Trạng thái" context="{'group_by': 'state'}"/>
                    <filter name="group_route" string="Tuyến" context="{'group_by': 'route_id'}"/>
                    <filter name="group_vehicle" string="Xe" context="{'group_by': 'vehicle_id'}"/>
                    <filter name="group_driver" string="Lái xe" context="{'group_by': 'driver_id'}"/>
                    <filter name="group_partner" string="Khách hàng" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_att_transport_order_kanban" model="ir.ui.view">
        <field name="name">att.transport.order.kanban</field>
        <field name="model">att.transport.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <div class="p-2">
                            <div class="fw-bold"><field name="name"/></div>
                            <div><field name="route_id"/></div>
                            <div class="text-muted"><field name="partner_id"/> · <field name="vehicle_id"/></div>
                            <div><field name="scheduled_date" widget="datetime"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_att_transport_order" model="ir.actions.act_window">
        <field name="name">Lệnh vận chuyển</field>
        <field name="res_model">att.transport.order</field>
        <field name="view_mode">list,kanban,form</field>
    </record>
</odoo>
