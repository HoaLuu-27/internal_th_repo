<odoo>
    <record id="privilege_th_transport" model="res.groups.privilege">
        <field name="name">Điều vận Trang Huy</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_th_driver" model="res.groups">
        <field name="name">Điều vận TH: Lái xe</field>
        <field name="privilege_id" ref="privilege_th_transport"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_th_dispatcher" model="res.groups">
        <field name="name">Điều vận TH: Điều vận viên</field>
        <field name="privilege_id" ref="privilege_th_transport"/>
        <field name="implied_ids" eval="[(4, ref('group_th_driver'))]"/>
    </record>

    <record id="rule_att_to_driver_own" model="ir.rule">
        <field name="name">TO: lái xe chỉ thấy lệnh của mình</field>
        <field name="model_id" ref="model_att_transport_order"/>
        <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_th_driver'))]"/>
    </record>

    <record id="rule_att_to_dispatcher_all" model="ir.rule">
        <field name="name">TO: điều vận viên thấy toàn bộ</field>
        <field name="model_id" ref="model_att_transport_order"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_th_dispatcher'))]"/>
    </record>

    <record id="rule_att_cost_line_driver_own" model="ir.rule">
        <field name="name">Chi phí: lái xe theo lệnh của mình</field>
        <field name="model_id" ref="model_att_transport_cost_line"/>
        <field name="domain_force">[('transport_order_id.driver_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_th_driver'))]"/>
    </record>

    <record id="rule_att_cost_line_dispatcher_all" model="ir.rule">
        <field name="name">Chi phí: điều vận viên thấy toàn bộ</field>
        <field name="model_id" ref="model_att_transport_cost_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_th_dispatcher'))]"/>
    </record>
</odoo>
