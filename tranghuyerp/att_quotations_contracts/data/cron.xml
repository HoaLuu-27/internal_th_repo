<odoo>
    <!-- Cron nhắc hợp đồng sắp hết hạn: quét HĐ đang hiệu lực có expired_date
         trong vòng 30 ngày tới, gửi mail template + log chatter (1 lần/HĐ) -->
    <record id="ir_cron_notify_expiring_contracts" model="ir.cron">
        <field name="name">ATT Contracts: Thông báo hợp đồng sắp hết hạn</field>
        <field name="model_id" ref="model_att_contract"/>
        <field name="state">code</field>
        <field name="code">model._cron_notify_expiring_contracts(days=30)</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
