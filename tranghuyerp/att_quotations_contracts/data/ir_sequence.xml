<odoo noupdate="0">
    <!-- Số thứ tự trong tên HĐ: {seq}/{ddmmyyyy}/HĐNT/TH-{viết tắt ĐT}/{yyyy} -->
    <record id="seq_attqc_contract_sale" model="ir.sequence">
        <field name="name">ATT Contract Sale</field>
        <field name="code">attqc.contract.sale</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_attqc_contract_purchase" model="ir.sequence">
        <field name="name">ATT Contract Purchase</field>
        <field name="code">attqc.contract.purchase</field>
        <field name="padding">3</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Số BÁO GIÁ tách khỏi số đơn thực thi để phân biệt ngay từ tên:
         - Báo giá bán : QT/2026/00001[/mã KH]   (SO thực thi giữ S00001 native)
         - Báo giá mua : QTM/2026/00001[/mã NCC] (PO thực thi giữ P00001 native)
         Mã KH/NCC lấy từ field ref trên danh bạ, ghép trong create (models).
         use_date_range: số tự reset về 00001 mỗi năm -->
    <record id="seq_attqc_sale_quotation" model="ir.sequence">
        <field name="name">ATT Báo giá bán</field>
        <field name="code">attqc.sale.quotation</field>
        <field name="prefix">QT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="use_date_range" eval="True"/>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_attqc_purchase_quotation" model="ir.sequence">
        <field name="name">ATT Báo giá mua (NCC)</field>
        <field name="code">attqc.purchase.quotation</field>
        <field name="prefix">QT/%(year)s/</field>
        <field name="padding">5</field>
        <field name="use_date_range" eval="True"/>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_attqc_sale_order_execution" model="ir.sequence">
        <field name="name">ATT Đơn hàng bán thực thi</field>
        <field name="code">attqc.sale.order.execution</field>
        <field name="prefix">SO/%(day)s%(month)s%(year)s/</field>
        <field name="padding">5</field>
        <field name="use_date_range" eval="True"/>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
