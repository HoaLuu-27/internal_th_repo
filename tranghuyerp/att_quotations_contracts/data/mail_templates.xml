<odoo>
    <record id="email_template_contract_draft" model="mail.template">
        <field name="name">Hợp đồng: Gửi bản nháp cho đối tác</field>
        <field name="model_id" ref="model_att_contract"/>
        <field name="subject">Bản nháp hợp đồng {{ object.name }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html" type="html">
            <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
            <p>Công ty Trang Huy xin gửi bản nháp hợp đồng <strong><t t-out="object.name"/></strong> để Quý công ty xem xét.</p>
            <p>Vui lòng liên hệ lại nếu có điều chỉnh.</p>
            <p>Trân trọng,<br/><t t-out="object.user_id.name"/></p>
        </field>
        <field name="report_template_ids" eval="[(4, ref('att_quotations_contracts.action_report_att_contract'))]"/>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_contract_validated" model="mail.template">
        <field name="name">Hợp đồng: Đã xác nhận hiệu lực</field>
        <field name="model_id" ref="model_att_contract"/>
        <field name="subject">Hợp đồng {{ object.name }} đã có hiệu lực</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html" type="html">
            <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
            <p>Hợp đồng <strong><t t-out="object.name"/></strong> giữa hai bên đã được ký kết và có hiệu lực từ ngày <t t-out="object.effective_date"/>.</p>
            <p>Vui lòng xem file hợp đồng đính kèm.</p>
            <p>Trân trọng,<br/><t t-out="object.user_id.name"/></p>
        </field>
        <field name="report_template_ids" eval="[(4, ref('att_quotations_contracts.action_report_att_contract'))]"/>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_contract_expiring" model="mail.template">
        <field name="name">Hợp đồng: Sắp hết hạn</field>
        <field name="model_id" ref="model_att_contract"/>
        <field name="subject">Thông báo: Hợp đồng {{ object.name }} sắp hết hạn</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="email_cc">{{ object.user_id.email }}</field>
        <field name="body_html" type="html">
            <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
            <p>Hợp đồng <strong><t t-out="object.name"/></strong> sẽ hết hạn vào ngày <strong><t t-out="object.expired_date"/></strong>.</p>
            <p>Vui lòng liên hệ để gia hạn hoặc ký hợp đồng mới nếu cần.</p>
            <p>Trân trọng,<br/><t t-out="object.user_id.name"/></p>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_appendix_draft" model="mail.template">
        <field name="name">Phụ lục: Gửi bản nháp cho đối tác</field>
        <field name="model_id" ref="model_att_contract_appendix"/>
        <field name="subject">Bản nháp phụ lục {{ object.name }} – {{ object.contract_id.name }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html" type="html">
            <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
            <p>Công ty Trang Huy xin gửi bản nháp phụ lục <strong><t t-out="object.name"/></strong> kèm theo Hợp đồng <strong><t t-out="object.contract_id.name"/></strong> để Quý công ty xem xét.</p>
            <p>Vui lòng liên hệ lại nếu có điều chỉnh.</p>
            <p>Trân trọng,<br/><t t-out="object.user_id.name"/></p>
        </field>
        <field name="report_template_ids" eval="[(4, ref('att_quotations_contracts.action_report_att_appendix'))]"/>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_appendix_signed" model="mail.template">
        <field name="name">Phụ lục: Gửi bản đã ký</field>
        <field name="model_id" ref="model_att_contract_appendix"/>
        <field name="subject">Phụ lục đã ký {{ object.name }} – {{ object.contract_id.name }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html" type="html">
            <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
            <p>Công ty Trang Huy xin gửi phụ lục <strong><t t-out="object.name"/></strong> đã được ký kết và có hiệu lực từ ngày <t t-out="object.effective_date or ''"/>.</p>
            <p>Vui lòng xem file đính kèm.</p>
            <p>Trân trọng,<br/><t t-out="object.user_id.name"/></p>
        </field>
        <field name="report_template_ids" eval="[(4, ref('att_quotations_contracts.action_report_att_appendix'))]"/>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_attqc_sale_quotation" model="mail.template">
        <field name="name">Trang Huy - Gửi báo giá khách hàng</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="subject">Báo giá vận chuyển {{ object.name }}</field>
        <field name="email_from">{{ object.company_id.email_formatted }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>

        <field name="report_template_ids"
               eval="[(4, ref('att_quotations_contracts.action_report_attqc_sale_quotation'))]"/>

        <field name="body_html" type="html">
            <div>
                <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
                <p>Trang Huy Logistics gửi Quý công ty báo giá vận chuyển <b><t t-out="object.name"/></b><t t-if="object.validity_date">, hiệu lực đến <t t-out="format_date(object.validity_date)"/></t>.</p>
                <p>Vui lòng xem file báo giá đính kèm và phản hồi xác nhận.</p>
                <p>Trân trọng,<br/><t t-out="object.user_id.name or object.company_id.name"/></p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_attqc_purchase_quotation" model="mail.template">
        <field name="name">Trang Huy - Gửi yêu cầu báo giá NCC</field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="subject">Yêu cầu báo giá {{ object.name }}</field>
        <field name="email_from">{{ object.company_id.email_formatted }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>

        <field name="report_template_ids"
               eval="[(4, ref('att_quotations_contracts.action_report_attqc_purchase_quotation'))]"/>

        <field name="body_html" type="html">
            <div>
                <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
                <p>Trang Huy Logistics gửi Quý đối tác yêu cầu báo giá <b><t t-out="object.name"/></b>.</p>
                <p>Vui lòng xem file đính kèm và phản hồi báo giá.</p>
                <p>Trân trọng,<br/><t t-out="object.user_id.name or object.company_id.name"/></p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>
