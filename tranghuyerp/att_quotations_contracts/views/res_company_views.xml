<odoo>
    <record id="view_company_form_att_report" model="ir.ui.view">
        <field name="name">res.company.form.att.report</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Report Trang Huy">
                    <group>
                        <group string="Hình ảnh report">
                            <field name="report_header_logo" widget="image" class="oe_avatar"/>
                            <field name="report_esg_logo" widget="image" class="oe_avatar"/>
                            <field name="report_footer_image" widget="image"/>
                        </group>
                        <group string="Chữ ký &amp; con dấu">
                            <field name="report_stamp_image" widget="image" class="oe_avatar"/>
                            <field name="report_signature_image" widget="image" class="oe_avatar"/>
                            <field name="report_signer_name"/>
                            <field name="report_signer_title"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
