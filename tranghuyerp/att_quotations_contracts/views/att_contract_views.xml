<odoo>
    <record id="view_att_contract_list" model="ir.ui.view">
        <field name="name">att.contract.list</field>
        <field name="model">att.contract</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="contract_type"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="effective_date"/>
                <field name="expired_date"/>
                <field name="appendix_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'running'"
                       decoration-info="state == 'confirm_requested'"
                       decoration-warning="state == 'liquidation_requested'"
                       decoration-muted="state in ('liquidated', 'cancelled')"/>
            </list>
        </field>
    </record>

    <record id="view_att_contract_form" model="ir.ui.view">
        <field name="name">att.contract.form</field>
        <field name="model">att.contract</field>
        <field name="arch" type="xml">
            <form string="Hợp đồng nguyên tắc">
                <header>
                    <!-- Mở popup chọn kênh (Email/Zalo; HĐ mua thêm Gọi điện) —
                         đường email chạy action_send_draft_to_partner như cũ -->
                    <button name="action_send_quotation" string="Gửi bản nháp"
                            type="object" invisible="state != 'draft'"/>
                    <button name="action_request_confirm" string="Yêu cầu xác nhận"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_validate" string="Xác nhận hiệu lực"
                            type="object" class="btn-primary"
                            invisible="state != 'confirm_requested'"
                            groups="att_quotations_contracts.group_att_contract_ceo"/>
                    <!-- Mua: tạo PO trực tiếp từ HĐNT, không bắt buộc qua phụ lục
                         (có phụ lục đang áp thì dòng + giá tự đổ từ phụ lục) -->
                    <button name="action_create_purchase_order" string="Tạo PO"
                            type="object"
                            invisible="state != 'running' or contract_type != 'purchase'"/>
                    <button name="action_request_liquidation" string="Yêu cầu thanh lý"
                            type="object" invisible="state != 'running'"/>
                    <button name="action_approve_liquidation" string="Duyệt thanh lý"
                            type="object" class="btn-primary"
                            invisible="state != 'liquidation_requested'"
                            groups="att_quotations_contracts.group_att_contract_ceo"/>
                    <button name="action_cancel" string="Hủy" type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_reset_to_draft" string="Về nháp" type="object"
                            invisible="state not in ('confirm_requested', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirm_requested,running,liquidated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <!-- 1 HĐNT ↔ N báo giá (SO draft / RFQ) -->
                        <button name="action_view_quotations" type="object"
                                class="oe_stat_button" icon="fa-file-o">
                            <field name="quotation_count" widget="statinfo" string="Báo giá"/>
                        </button>
                        <button name="action_view_appendix" type="object"
                                class="oe_stat_button" icon="fa-files-o">
                            <field name="appendix_count" widget="statinfo" string="Phụ lục"/>
                        </button>
                        <!-- CHỈ HĐ MUA có PO thực thi trực tiếp (tạo từ HĐNT/phụ lục).
                             HĐ bán KHÔNG có nút này: SO thực thi thuộc phụ lục -->
                        <button name="action_view_orders" type="object"
                                class="oe_stat_button" icon="fa-truck"
                                invisible="contract_type != 'purchase'">
                            <field name="order_count" widget="statinfo" string="PO thực thi"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Thông tin chung">
                            <field name="contract_type" readonly="state != 'draft'"/>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <!-- Điểm nối báo giá native: SO báo giá (bán) / RFQ thắng (mua) -->
                            <field name="source_sale_order_id"
                                   invisible="contract_type != 'sale'"
                                   readonly="state != 'draft'"/>
                            <field name="source_purchase_order_id"
                                   invisible="contract_type != 'purchase'"
                                   readonly="state != 'draft'"/>
                            <field name="active_appendix_id" readonly="1"/>
                            <field name="user_id"/>
                            <field name="company_id"/>
                            <field name="currency_id"/>
                        </group>
                        <group string="Hiệu lực hợp đồng">
                            <field name="effective_date" readonly="state != 'draft'"/>
                            <field name="expired_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Thông tin đối tác">
                            <group>
                                <group>
                                    <field name="partner_address"/>
                                    <field name="partner_phone"/>
                                    <field name="partner_email"/>
                                    <field name="partner_tax_code"/>
                                </group>
                                <group>
                                    <field name="partner_bank_account"/>
                                    <!-- Nhiều người đại diện ký được — chọn từ
                                         contact của đối tác, chức vụ lấy từ contact -->
                                    <field name="partner_representative_ids"
                                           widget="many2many_tags"/>
                                    <field name="partner_position" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Thanh toán">
                            <group>
                                <group>
                                    <field name="payment_term_id"/>
                                    <field name="payment_method"/>
                                    <field name="payment_deadline_days"/>
                                </group>
                                <group>
                                    <field name="payment_document_note"/>
                                    <field name="payment_note"/>
                                    <field name="late_payment_penalty_note"/>
                                    <field name="waiting_fee_note"/>
                                </group>
                            </group>
                        </page>
                        <page string="Điều khoản">
                            <field name="term_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <!-- Số điều tự đánh theo vị trí — kéo thả là số
                                         cập nhật, PDF in đúng số này -->
                                    <field name="display_title" readonly="1"/>
                                    <field name="clause_id"
                                           domain="[('clause_type', 'in', [parent.contract_type, 'both'])]"
                                           options="{'no_create': True}"/>
                                    <field name="is_fixed" readonly="1"/>
                                    <field name="title" readonly="is_fixed"/>
                                    <field name="content" widget="html" readonly="is_fixed" optional="show"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Thanh lý"
                              invisible="state not in ('running', 'liquidation_requested', 'liquidated')">
                            <group>
                                <group>
                                    <field name="liquidation_reason_id"/>
                                    <field name="liquidation_note"/>
                                </group>
                                <group>
                                    <field name="liquidation_requested_by"/>
                                    <field name="liquidation_requested_date"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_att_contract_sale" model="ir.actions.act_window">
        <field name="name">Hợp đồng bán</field>
        <field name="res_model">att.contract</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('contract_type', '=', 'sale')]</field>
        <field name="context">{'default_contract_type': 'sale'}</field>
    </record>

    <record id="action_att_contract_purchase" model="ir.actions.act_window">
        <field name="name">Hợp đồng mua</field>
        <field name="res_model">att.contract</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('contract_type', '=', 'purchase')]</field>
        <field name="context">{'default_contract_type': 'purchase'}</field>
    </record>
</odoo>
