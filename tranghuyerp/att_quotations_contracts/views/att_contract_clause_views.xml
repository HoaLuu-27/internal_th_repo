<odoo>
    <record id="view_att_clause_list" model="ir.ui.view">
        <field name="name">att.contract.clause.list</field>
        <field name="model">att.contract.clause</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="clause_type"/>
                <field name="title"/>
                <field name="is_fixed"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_att_clause_form" model="ir.ui.view">
        <field name="name">att.contract.clause.form</field>
        <field name="model">att.contract.clause</field>
        <field name="arch" type="xml">
            <form string="Điều khoản mẫu">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="clause_type"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="is_fixed"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Nội dung">
                        <!-- Title KHÔNG gõ kèm số "Điều X" — số tự đánh theo
                             vị trí dòng khi load vào hợp đồng -->
                        <field name="title" placeholder="VD: TRƯỜNG HỢP BẤT KHẢ KHÁNG (không gõ số Điều)"/>
                        <field name="content" widget="html" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_att_clause" model="ir.actions.act_window">
        <field name="name">Thư viện điều khoản</field>
        <field name="res_model">att.contract.clause</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
