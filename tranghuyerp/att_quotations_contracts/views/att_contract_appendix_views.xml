<odoo>
    <record id="view_att_appendix_list" model="ir.ui.view">
        <field name="name">att.contract.appendix.list</field>
        <field name="model">att.contract.appendix</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="contract_id"/>
                <field name="appendix_type"/>
                <field name="partner_id"/>
                <field name="effective_date"/>
                <field name="amount_total" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('confirmed', 'done')"
                       decoration-info="state == 'pending_approval'"
                       decoration-muted="state in ('superseded', 'cancelled')"/>
            </list>
        </field>
    </record>

    <record id="view_att_appendix_form" model="ir.ui.view">
        <field name="name">att.contract.appendix.form</field>
        <field name="model">att.contract.appendix</field>
        <field name="arch" type="xml">
            <form string="Phụ lục hợp đồng">
                <header>
                    <!-- Kéo dòng giá từ báo giá native — thay nhập tay 3 lần -->
                    <button name="action_load_source_lines" string="Nạp dòng từ báo giá"
                            type="object" invisible="state != 'draft'"/>
                    <!-- Mở popup chọn kênh (Email/Zalo; PL mua thêm Gọi điện) —
                         đường email chạy action_send_draft như cũ -->
                    <button name="action_send_quotation" string="Gửi bản nháp"
                            type="object" invisible="state != 'draft'"/>
                    <button name="action_request_approval" string="Yêu cầu duyệt"
                            type="object" class="btn-primary"
                            invisible="state not in ('draft', 'sent_draft')"/>
                    <button name="action_confirm" string="Duyệt phụ lục"
                            type="object" class="btn-primary"
                            invisible="state != 'pending_approval'"
                            groups="att_quotations_contracts.group_tranghuy_managers_sale_purchase"/>
                    <button name="action_send_signed" string="Gửi bản đã ký"
                            type="object" invisible="state not in ('confirmed', 'done')"/>
                    <button name="action_create_sale_order" string="Tạo SO thực thi"
                            type="object" class="btn-primary"
                            invisible="state not in ('confirmed', 'done') or appendix_type != 'sale'"/>
                    <button name="action_create_purchase_order" string="Tạo PO thực thi"
                            type="object" class="btn-primary"
                            invisible="state not in ('confirmed', 'done') or appendix_type != 'purchase'"/>
                    <button name="action_cancel" string="Hủy" type="object"
                            invisible="state in ('done', 'superseded', 'cancelled')"/>
                    <button name="action_reset_to_draft" string="Về nháp" type="object"
                            invisible="state not in ('sent_draft', 'pending_approval', 'cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending_approval,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_orders" type="object"
                                class="oe_stat_button" icon="fa-truck">
                            <field name="order_count" widget="statinfo" string="Đơn thực thi"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Thông tin chung">
                            <field name="contract_id" readonly="state != 'draft'"/>
                            <field name="appendix_type" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="user_id"/>
                            <field name="company_id"/>
                            <field name="currency_id"/>
                            <!-- Nguồn kéo dòng giá: SO báo giá (bán) / RFQ thắng (mua) -->
                            <field name="source_sale_order_id"
                                   invisible="appendix_type != 'sale'"
                                   readonly="state != 'draft'"/>
                            <field name="source_purchase_order_id"
                                   invisible="appendix_type != 'purchase'"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Hiệu lực &amp; thay thế">
                            <field name="effective_date"/>
                            <field name="expired_date"/>
                            <!-- Đổi giá → PL mới thay PL cũ, không sửa đè PL đã ký -->
                            <field name="replaces_appendix_id" readonly="state != 'draft'"/>
                            <field name="replaced_by_id" readonly="1"
                                   invisible="not replaced_by_id"/>
                        </group>
                    </group>
                    <group string="Thông tin đối tác ký">
                        <group>
                            <!-- Kế thừa từ HĐ, sửa được theo từng phụ lục -->
                            <field name="partner_representative_ids"
                                   widget="many2many_tags"/>
                            <field name="partner_position" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dòng phụ lục">
                            <field name="appendix_line_ids" widget="section_and_note_one2many">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_line_control" string="Thêm dòng"/>
                                        <create name="add_section_control" string="Thêm nhóm"
                                                context="{'default_display_type': 'line_section'}"/>
                                        <create name="add_note_control" string="Thêm ghi chú"
                                                context="{'default_display_type': 'line_note'}"/>
                                    </control>
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_type" column_invisible="1"/>
                                    <field name="is_mapping" optional="show"/>
                                    <field name="name" widget="section_and_note_text"/>
                                    <field name="pickup_location" optional="show"/>
                                    <field name="delivery_location" optional="show"/>
                                    <field name="load_capacity" optional="hide"/>
                                    <field name="vehicle_id" optional="hide"/>
                                    <field name="transport_mode_id" optional="show"/>
                                    <field name="cargo_description" optional="hide"/>
                                    <field name="service_type_id" optional="hide"/>
                                    <field name="product_id" optional="hide"/>
                                    <field name="quantity"/>
                                    <field name="uom_id" optional="show"/>
                                    <field name="price_unit"/>
                                    <field name="tax_ids" widget="many2many_tags" optional="show"/>
                                    <field name="price_subtotal" widget="monetary"/>
                                    <field name="price_total" widget="monetary" optional="hide"/>
                                    <field name="extra_note" optional="hide"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="amount_untaxed" widget="monetary"/>
                                <field name="amount_tax" widget="monetary"/>
                                <field name="amount_total" widget="monetary" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Cấu hình PDF phụ lục" name="attqc_pdf_config">
                            <div class="text-muted mb-2">
                                Bỏ tick "In vào PDF" ở các dòng không muốn đưa vào file phụ lục khi in/gửi đối tác.
                                Tổng tiền trên file PDF chỉ tính theo các dòng được in.
                            </div>
                            <field name="appendix_line_ids">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="display_type" column_invisible="1"/>
                                    <field name="name" widget="section_and_note_text" readonly="1"/>
                                    <field name="pickup_location" readonly="1"/>
                                    <field name="delivery_location" readonly="1"/>
                                    <field name="quantity" readonly="1"/>
                                    <field name="price_unit" readonly="1"/>
                                    <field name="price_subtotal" widget="monetary" readonly="1"/>
                                    <field name="rpt_include" widget="boolean_toggle"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Điều chỉnh giá dầu" invisible="appendix_type != 'sale'">
                            <group>
                                <group>
                                    <field name="fuel_ref_price"/>
                                    <field name="fuel_ref_date"/>
                                </group>
                                <group>
                                    <field name="fuel_ratio"/>
                                    <field name="fuel_note"/>
                                </group>
                            </group>
                        </page>
                        <page string="Thông tin bổ sung">
                            <field name="extra_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="key"/>
                                    <field name="value"/>
                                    <field name="line_id"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_att_appendix_sale" model="ir.actions.act_window">
        <field name="name">Phụ lục bán</field>
        <field name="res_model">att.contract.appendix</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('appendix_type', '=', 'sale')]</field>
        <field name="context">{'default_appendix_type': 'sale'}</field>
    </record>

    <record id="action_att_appendix_purchase" model="ir.actions.act_window">
        <field name="name">Phụ lục mua</field>
        <field name="res_model">att.contract.appendix</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('appendix_type', '=', 'purchase')]</field>
        <field name="context">{'default_appendix_type': 'purchase'}</field>
    </record>
</odoo>
