<odoo>
    <!-- ĐƠN ĐẶT HÀNG VẬN CHUYỂN (đã có hợp đồng khung) — port từ mẫu giấy
         VinAlpha/TrangHuy: in cho SO THỰC THI đã confirm (state = sale).
         Chiều vai trò: KH = bên "Yêu cầu bởi", Trang Huy = "Nhà cung cấp". -->
    <record id="action_report_attqc_sale_execution_order" model="ir.actions.report">
        <field name="name">Đơn đặt hàng vận chuyển (TH)</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">att_quotations_contracts.report_attqc_sale_execution_order</field>
        <field name="report_file">att_quotations_contracts.report_attqc_sale_execution_order</field>
        <field name="print_report_name">'Don_dat_hang_%s' % (object.name or '').replace('/', '_')</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="domain">[('state', '=', 'sale')]</field>
    </record>

    <template id="report_attqc_sale_execution_order">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="doc">
                <t t-set="company" t-value="doc.company_id or res_company"/>
                <t t-set="contract" t-value="doc.att_appendix_id.contract_id or doc.att_contract_id"/>
                <t t-set="service_lines" t-value="doc.order_line.filtered(lambda l: not l.display_type)"/>
                <t t-set="first_line" t-value="service_lines[:1]"/>

                <div class="page" style="font-size:12px;">

                    <!-- TIÊU ĐỀ -->
                    <div style="text-align:center;margin-bottom:4px;">
                        <div style="font-size:14px;font-weight:bold;">
                            ĐƠN ĐẶT HÀNG VẬN CHUYỂN<t t-if="contract"> (ĐÃ CÓ HỢP ĐỒNG KHUNG)</t>
                        </div>
                        <div style="font-weight:bold;">Số đơn hàng: <span t-field="doc.name"/></div>
                        <div t-if="contract" style="font-style:italic;">
                            (Kèm theo Hợp đồng số: <span t-esc="contract.name"/>
                            <t t-if="contract.effective_date">
                                ngày <span t-esc="contract.effective_date.strftime('%d')"/>
                                tháng <span t-esc="contract.effective_date.strftime('%m')"/>
                                năm <span t-esc="contract.effective_date.strftime('%Y')"/>
                            </t>)
                        </div>
                    </div>

                    <!-- THÔNG TIN CHUNG -->
                    <table style="width:100%;border-collapse:collapse;margin-bottom:12px;">
                        <tr>
                            <td style="border:1px solid #000;padding:4px 6px;width:50%;">
                                <b>Ngày:</b>
                                <span t-esc="doc.date_order.strftime('%d/%m/%Y') if doc.date_order else ''"/>
                            </td>
                            <td style="border:1px solid #000;padding:4px 6px;">
                                <b>Ngày giao hàng:</b>
                                <t t-if="doc.commitment_date">
                                    <span t-esc="doc.commitment_date.strftime('%d/%m/%Y')"/>
                                </t>
                                <t t-else="">Thực tế theo tiến độ của dự án</t>
                            </td>
                        </tr>
                        <tr>
                            <td style="border:1px solid #000;padding:4px 6px;">
                                <b>Đơn hàng:</b>
                                <t t-if="first_line and first_line.pickup_location and first_line.delivery_location">
                                    Đơn xe vận chuyển hàng hóa từ <span t-esc="first_line.pickup_location"/>
                                    sang <span t-esc="first_line.delivery_location"/>
                                </t>
                                <t t-else=""><span t-field="doc.name"/></t>
                            </td>
                            <td style="border:1px solid #000;padding:4px 6px;">
                                <b>Phương thức vận chuyển:</b>
                                <t t-if="first_line and first_line.transport_mode_id">
                                    <span t-esc="first_line.transport_mode_id.name"/>
                                </t>
                                <t t-else="">Giao hàng tại công trình</t>
                            </td>
                        </tr>
                        <tr>
                            <td style="border:1px solid #000;padding:4px 6px;">
                                <b>Yêu cầu bởi:</b>
                                <span t-field="doc.partner_id.name" style="text-transform:uppercase;"/>
                            </td>
                            <td style="border:1px solid #000;padding:4px 6px;">
                                <b>Địa chỉ bốc hàng hoá:</b>
                                <span t-if="first_line" t-esc="first_line.pickup_location or ''"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="border:1px solid #000;padding:4px 6px;">
                                <b>Nhà cung cấp:</b>
                                <span t-esc="company.name" style="text-transform:uppercase;"/>
                            </td>
                            <td style="border:1px solid #000;padding:4px 6px;">
                                <b>Địa chỉ hạ hàng:</b>
                                <span t-if="first_line" t-esc="first_line.delivery_location or ''"/>
                            </td>
                        </tr>
                    </table>

                    <!-- 1. DANH SÁCH HÀNG HÓA -->
                    <div style="font-weight:bold;margin-bottom:6px;">1. Danh sách Hàng Hóa:</div>
                    <table style="width:100%;border-collapse:collapse;font-size:11px;">
                        <thead>
                            <tr>
                                <th style="border:1px solid #000;padding:5px;text-align:center;width:4%;">TT</th>
                                <th style="border:1px solid #000;padding:5px;text-align:center;">Tên hàng hóa</th>
                                <th style="border:1px solid #000;padding:5px;text-align:center;width:9%;">Xuất xứ</th>
                                <th style="border:1px solid #000;padding:5px;text-align:center;width:8%;">ĐVT</th>
                                <th style="border:1px solid #000;padding:5px;text-align:center;width:8%;">Khối Lượng</th>
                                <th style="border:1px solid #000;padding:5px;text-align:center;width:11%;">Đơn giá (chưa VAT)</th>
                                <th style="border:1px solid #000;padding:5px;text-align:center;width:11%;">Thành Tiền (chưa VAT)</th>
                                <th style="border:1px solid #000;padding:5px;text-align:center;width:7%;">Thuế VAT</th>
                                <th style="border:1px solid #000;padding:5px;text-align:center;width:11%;">Thành Tiền (gồm VAT)</th>
                                <th style="border:1px solid #000;padding:5px;text-align:center;width:12%;">Hồ sơ/tài liệu kèm theo (nếu có)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="service_lines" t-as="line">
                                <td style="border:1px solid #000;padding:5px;text-align:center;">
                                    <span t-esc="line_index + 1"/>
                                </td>
                                <td style="border:1px solid #000;padding:5px;">
                                    <span t-field="line.name"/>
                                    <t t-if="line.pickup_location and line.delivery_location">
                                        <br/><span style="font-style:italic;" t-esc="'%s sang %s' % (line.pickup_location, line.delivery_location)"/>
                                    </t>
                                </td>
                                <td style="border:1px solid #000;padding:5px;text-align:center;">
                                    <span t-if="line.cargo_description" t-field="line.cargo_description"/>
                                </td>
                                <td style="border:1px solid #000;padding:5px;text-align:center;">
                                    <span t-if="line.product_uom_id" t-field="line.product_uom_id"/>
                                </td>
                                <td style="border:1px solid #000;padding:5px;text-align:center;">
                                    <span t-field="line.product_uom_qty"/>
                                </td>
                                <td style="border:1px solid #000;padding:5px;text-align:right;">
                                    <span t-field="line.price_unit"
                                          t-options="{'widget':'monetary','display_currency':doc.currency_id}"/>
                                </td>
                                <td style="border:1px solid #000;padding:5px;text-align:right;">
                                    <span t-field="line.price_subtotal"
                                          t-options="{'widget':'monetary','display_currency':doc.currency_id}"/>
                                </td>
                                <td style="border:1px solid #000;padding:5px;text-align:center;">
                                    <span t-esc="', '.join(line.tax_ids.mapped('name'))"/>
                                </td>
                                <td style="border:1px solid #000;padding:5px;text-align:right;">
                                    <span t-field="line.price_total"
                                          t-options="{'widget':'monetary','display_currency':doc.currency_id}"/>
                                </td>
                                <td style="border:1px solid #000;padding:5px;">
                                    <span t-if="line.att_line_note" t-field="line.att_line_note"/>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="6" style="border:1px solid #000;padding:5px;text-align:right;font-weight:bold;">Thành tiền:</td>
                                <td style="border:1px solid #000;padding:5px;text-align:right;font-weight:bold;">
                                    <span t-field="doc.amount_untaxed"
                                          t-options="{'widget':'monetary','display_currency':doc.currency_id}"/>
                                </td>
                                <td style="border:1px solid #000;"/>
                                <td style="border:1px solid #000;padding:5px;text-align:right;font-weight:bold;">
                                    <span t-field="doc.amount_total"
                                          t-options="{'widget':'monetary','display_currency':doc.currency_id}"/>
                                </td>
                                <td style="border:1px solid #000;"/>
                            </tr>
                        </tfoot>
                    </table>

                    <div style="margin-top:6px;">
                        <b>Bằng chữ:</b>
                        <span style="font-style:italic;"
                              t-esc="doc.currency_id.amount_to_text(doc.amount_total)"/>./.
                    </div>

                    <!-- 2. NỘI DUNG KHÁC -->
                    <div style="font-weight:bold;margin-top:12px;">2. Nội dung khác (nếu có):</div>
                    <div t-if="doc.note" style="margin-top:4px;">
                        <span t-field="doc.note"/>
                    </div>
                    <div t-else="" style="min-height:30px;"/>

                    <!-- KÝ TÊN: trái = KH (bên yêu cầu), phải = Trang Huy (NCC) -->
                    <table style="width:100%;margin-top:24px;border-collapse:collapse;">
                        <tr>
                            <td style="width:50%;text-align:center;vertical-align:top;padding:0 8px;">
                                <div style="font-weight:bold;text-transform:uppercase;">
                                    <span t-field="doc.partner_id.name"/>
                                </div>
                                <div style="min-height:100px;"/>
                                <div style="font-weight:bold;">ĐẠI DIỆN BÊN YÊU CẦU</div>
                            </td>
                            <td style="width:50%;text-align:center;vertical-align:top;padding:0 8px;">
                                <div style="font-weight:bold;text-transform:uppercase;">
                                    <span t-esc="company.name"/>
                                </div>
                                <div style="position:relative;min-height:100px;">
                                    <img t-if="company.report_stamp_image"
                                         t-att-src="image_data_uri(company.report_stamp_image)"
                                         style="position:absolute;width:100px;top:5px;left:60px;z-index:1;"/>
                                    <img t-if="company.report_signature_image"
                                         t-att-src="image_data_uri(company.report_signature_image)"
                                         style="position:absolute;width:130px;top:20px;left:90px;z-index:2;"/>
                                </div>
                                <div style="font-weight:bold;text-transform:uppercase;">
                                    <span t-esc="company.report_signer_title or 'GIÁM ĐỐC'"/>
                                </div>
                                <div style="font-weight:bold;font-style:italic;">
                                    <span t-esc="company.report_signer_name or 'Nguyễn Thị Bích Thủy'"/>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <!-- FOOTER -->
                    <img t-if="company.report_footer_image"
                         t-att-src="image_data_uri(company.report_footer_image)"
                         style="width:100%;margin-top:20px;"/>
                </div>
            </t>
        </t>
    </template>
</odoo>
