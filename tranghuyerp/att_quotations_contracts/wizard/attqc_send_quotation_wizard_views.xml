<odoo>
    <record id="view_attqc_send_quotation_wizard_form" model="ir.ui.view">
        <field name="name">attqc.send.quotation.wizard.form</field>
        <field name="model">attqc.send.quotation.wizard</field>
        <field name="arch" type="xml">
            <form string="Gửi báo giá">
                <group>
                    <field name="res_model" invisible="1"/>
                    <field name="res_id" invisible="1"/>
                    <field name="channel" widget="radio"/>
                </group>
                <footer>
                    <button name="action_send" string="Gửi" type="object" class="btn-primary"/>
                    <button string="Hủy" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
