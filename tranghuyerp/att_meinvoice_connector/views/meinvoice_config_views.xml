<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Form View ── -->
    <record id="meinvoice_config_view_form" model="ir.ui.view">
        <field name="name">meinvoice.config.form</field>
        <field name="model">meinvoice.config</field>
        <field name="arch" type="xml">
            <form string="Cấu hình MeInvoice">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Tên cấu hình..."/>
                        </h1>
                    </div>

                    <!-- Action buttons -->
                    <div class="o_row mb-3">
                        <button string="Test kết nối"
                                name="action_test_connection"
                                type="object"
                                class="btn btn-primary"/>
                        <button string="Lấy Templates"
                                name="action_fetch_templates"
                                type="object"
                                class="btn btn-secondary"/>
                        <button string="Refresh Token"
                                name="action_refresh_token"
                                type="object"
                                class="btn btn-secondary"/>
                    </div>

                    <group>
                        <group string="Thông tin kết nối">
                            <field name="company_id"/>
                            <field name="app_id"/>
                            <field name="tax_code"/>
                            <field name="username"/>
                            <field name="password" password="True"/>
                        </group>
                        <group string="Cấu hình hóa đơn">
                            <field name="inv_series"/>
                            <field name="invoice_template_id"/>
                            <field name="sign_type"/>
                            <field name="active"/>
                        </group>
                    </group>

                    <!-- HSM: chỉ hiện khi SignType=1 -->
                    <group string="Cấu hình USB Token / HSM"
                           invisible="sign_type != '1'">
                        <field name="hsm_host"/>
                        <field name="hsm_pin" password="True"/>
                    </group>

                    <!-- Endpoints -->
                    <group string="Endpoints API">
                        <group string="Auth &amp; Templates">
                            <field name="base_url"/>
                            <field name="endpoint_token"/>
                            <field name="endpoint_templates"/>
                        </group>
                        <group string="Sandbox V2 (/webapp/)">
                            <field name="endpoint_preview"/>
                            <field name="endpoint_insert"/>
                            <field name="endpoint_getlist"/>
                            <field name="endpoint_paging"/>
                            <field name="endpoint_viewrefid"/>
                            <field name="endpoint_delete"/>
                        </group>
                    </group>

                    <group string="Endpoints Production V1 (/invoice/)">
                        <group>
                            <field name="endpoint_publish"/>
                            <field name="endpoint_publishview"/>
                        </group>
                        <group>
                            <field name="endpoint_sendemail"/>
                        </group>
                    </group>

                    <!-- Token cache -->
                    <group string="Token Cache">
                        <field name="access_token" readonly="1"/>
                        <field name="token_expiry" readonly="1"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Tree View ── -->
    <record id="meinvoice_config_view_tree" model="ir.ui.view">
        <field name="name">meinvoice.config.tree</field>
        <field name="model">meinvoice.config</field>
        <field name="arch" type="xml">
            <list string="Cấu hình MeInvoice">
                <field name="name"/>
                <field name="company_id"/>
                <field name="base_url"/>
                <field name="tax_code"/>
                <field name="inv_series"/>
                <field name="invoice_template_id"/>
                <field name="sign_type"/>
                <field name="token_expiry"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ── Search View ── -->
    <record id="meinvoice_config_view_search" model="ir.ui.view">
        <field name="name">meinvoice.config.search</field>
        <field name="model">meinvoice.config</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="tax_code"/>
                <field name="company_id"/>
                <filter name="filter_active"
                        string="Đang dùng"
                        domain="[('active', '=', True)]"/>
                <filter name="filter_inactive"
                        string="Ngừng dùng"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="group_company"
                        string="Công ty"
                        context="{'group_by': 'company_id'}"/>
            </search>
        </field>
    </record>

    <!-- ── Action ── -->
    <record id="action_meinvoice_config" model="ir.actions.act_window">
        <field name="name">Cấu hình MeInvoice</field>
        <field name="res_model">meinvoice.config</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="meinvoice_config_view_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>

</odoo>