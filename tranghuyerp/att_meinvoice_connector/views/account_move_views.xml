<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="account_move_view_form_meinvoice" model="ir.ui.view">
        <field name="name">account.move.form.meinvoice</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Buttons trên form -->
            <xpath expr="//div[@name='button_box']" position="after">
                <div name="meinvoice_buttons"
                     invisible="move_type != 'out_invoice' or state != 'posted'">

                    <button string="Tạo HĐ nháp MeInvoice"
                            name="action_meinvoice_insert"
                            type="object"
                            class="btn-primary"
                            invisible="not meinvoice_can_send"/>

                    <button string="Xem trước HĐ"
                            name="action_meinvoice_preview"
                            type="object"
                            class="btn-secondary"
                            invisible="not meinvoice_ref_id"/>

                    <button string="Cập nhật trạng thái"
                            name="action_meinvoice_refresh_status"
                            type="object"
                            class="btn-secondary"
                            invisible="meinvoice_state != 'draft_sent'"/>

                    <button string="Xóa HĐ nháp"
                            name="action_meinvoice_delete_draft"
                            type="object"
                            class="btn-danger"
                            invisible="meinvoice_state != 'draft_sent'"/>
                </div>
            </xpath>

            <!-- Tab MeInvoice E-Invoice -->
            <xpath expr="//notebook" position="inside">
                <page string="MeInvoice E-Invoice"
                      name="meinvoice_tab"
                      invisible="move_type != 'out_invoice'">
                    <group>
                        <group string="Trạng thái">
                            <field name="meinvoice_state" widget="badge"
                                   decoration-success="meinvoice_state == 'published'"
                                   decoration-warning="meinvoice_state in ('pending', 'draft_sent')"
                                   decoration-danger="meinvoice_state == 'error'"
                                   decoration-muted="meinvoice_state == 'not_sent'"/>
                            <field name="meinvoice_ref_id"/>
                            <field name="meinvoice_inv_no"/>
                            <field name="meinvoice_transaction_id"/>
                            <field name="meinvoice_inv_date"/>
                        </group>
                        <group string="Liên kết">
                            <!-- Chỉ hiện ID record, không smart button -->
                            <field name="meinvoice_invoice_id"
                                   readonly="1"
                                   invisible="not meinvoice_invoice_id"/>
                        </group>
                    </group>


                    <group string="Thông tin lỗi"
                           invisible="meinvoice_state != 'error'">
                        <field name="meinvoice_error_msg"
                               nolabel="1"
                               readonly="1"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>