<odoo>
    <data noupdate="1">
        <record id="seq_th_vehicle_handover" model="ir.sequence">
            <field name="name">Biên bản bàn giao xe</field>
            <field name="code">att.vehicle.handover</field>
            <field name="prefix">BG/%(range_year)s/</field>
            <field name="padding">4</field>
            <field name="use_date_range" eval="True"/>
        </record>

        <record id="cron_notify_expiring_documents" model="ir.cron">
            <field name="name">Fleet TH: Cảnh báo giấy tờ xe sắp hết hạn</field>
            <field name="model_id" ref="model_att_vehicle_document"/>
            <field name="state">code</field>
            <field name="code">model._cron_notify_expiring_documents()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <record id="cron_check_maintenance_due" model="ir.cron">
            <field name="name">Fleet TH: Cảnh báo xe tới hạn bảo dưỡng (theo km)</field>
            <field name="model_id" ref="fleet.model_fleet_vehicle"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_maintenance_due()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
