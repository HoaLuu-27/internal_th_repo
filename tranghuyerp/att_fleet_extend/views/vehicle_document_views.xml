<odoo>
    <record id="view_th_vehicle_document_list" model="ir.ui.view">
        <field name="name">att.vehicle.document.list</field>
        <field name="model">att.vehicle.document</field>
        <field name="arch" type="xml">
            <list decoration-danger="expiry_state == 'expired'"
                  decoration-warning="expiry_state == 'expiring'">
                <field name="vehicle_id"/>
                <field name="doc_type"/>
                <field name="name"/>
                <field name="issue_date" optional="hide"/>
                <field name="expiry_date"/>
                <field name="days_to_expiry"/>
                <field name="expiry_state" widget="badge"
                       decoration-success="expiry_state == 'valid'"
                       decoration-warning="expiry_state == 'expiring'"
                       decoration-danger="expiry_state == 'expired'"/>
            </list>
        </field>
    </record>

    <record id="view_th_vehicle_document_form" model="ir.ui.view">
        <field name="name">att.vehicle.document.form</field>
        <field name="model">att.vehicle.document</field>
        <field name="arch" type="xml">
            <form string="Giấy tờ xe">
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="doc_type"/>
                            <field name="name"/>
                            <field name="attachment" filename="attachment_filename"/>
                            <field name="attachment_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <field name="days_to_expiry"/>
                            <field name="expiry_state" widget="badge"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Ghi chú..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_th_vehicle_document" model="ir.actions.act_window">
        <field name="name">Giấy tờ xe</field>
        <field name="res_model">att.vehicle.document</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Chưa có giấy tờ xe nào</p>
            <p>Upload đăng kiểm, bảo hiểm, phù hiệu... — hệ thống tự cảnh báo trước khi hết hạn.</p>
        </field>
    </record>

    <menuitem id="menu_th_vehicle_document" name="Giấy tờ xe"
              parent="fleet.fleet_vehicles" action="action_th_vehicle_document"
              sequence="25"/>
</odoo>
