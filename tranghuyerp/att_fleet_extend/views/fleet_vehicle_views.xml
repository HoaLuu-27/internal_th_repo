<odoo>
    <record id="fleet_vehicle_view_form_th" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.att.extend</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_view_documents" type="object"
                        class="oe_stat_button" icon="fa-file-text-o">
                    <field name="document_count" widget="statinfo" string="Giấy tờ xe"/>
                </button>
                <button name="action_view_handovers" type="object"
                        class="oe_stat_button" icon="fa-exchange">
                    <field name="handover_count" widget="statinfo" string="Bàn giao"/>
                </button>
            </div>
            <notebook position="inside">
                <page string="Điều vận TH" name="th_dispatch">
                    <group>
                        <group string="Trạng thái &amp; lái xe">
                            <field name="th_state" widget="badge"
                                   decoration-success="th_state == 'available'"
                                   decoration-info="th_state == 'in_transit'"
                                   decoration-warning="th_state == 'maintenance'"
                                   decoration-danger="th_state == 'broken'"/>
                            <field name="default_driver_employee_id"/>
                        </group>
                        <group string="Năng lực chở">
                            <field name="payload_capacity"/>
                            <field name="volume_capacity"/>
                        </group>
                        <group string="Bảo dưỡng theo km">
                            <field name="service_interval_km"/>
                            <field name="last_service_odometer"/>
                            <field name="km_to_service" readonly="1"
                                   decoration-danger="km_to_service &lt;= 0"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <record id="fleet_vehicle_view_search_th" model="ir.ui.view">
        <field name="name">fleet.vehicle.search.att.extend</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_search"/>
        <field name="arch" type="xml">
            <search position="inside">
                <filter name="th_available" string="Xe sẵn sàng"
                        domain="[('th_state', '=', 'available')]"/>
                <filter name="th_in_transit" string="Xe đang chạy"
                        domain="[('th_state', '=', 'in_transit')]"/>
                <filter name="th_maintenance" string="Bảo dưỡng / Hỏng"
                        domain="[('th_state', 'in', ('maintenance', 'broken'))]"/>
            </search>
        </field>
    </record>
</odoo>
