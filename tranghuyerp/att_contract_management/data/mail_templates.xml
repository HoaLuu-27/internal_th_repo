<odoo>
    <record id="email_template_contract_draft" model="mail.template">
        <field name="name">Hợp đồng: Gửi bản nháp cho đối tác</field>
        <field name="model_id" ref="model_att_contract"/>
        <field name="subject">Bản nháp hợp đồng {{ object.name }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html" type="html">
            <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
            <p>Công ty Trang Huy xin gửi bản nháp hợp đồng <strong><t t-out="object.name"/></strong> để Quý công ty xem xét.</p>
            <p>Vui lòng liên hệ lại nếu có điều chỉnh.</p>
            <p>Trân trọng,<br/><t t-out="object.user_id.name"/></p>
        </field>
        <field name="report_template_ids" eval="[(4, ref('att_contract_management.action_report_att_contract'))]"/>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_appendix_draft" model="mail.template">
        <field name="name">Phụ lục: Gửi bản nháp cho đối tác</field>
        <field name="model_id" ref="model_att_contract_appendix"/>
        <field name="subject">Bản nháp phụ lục {{ object.name }} – {{ object.contract_id.name }}</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="body_html" type="html">
            <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
            <p>Công ty Trang Huy xin gửi bản nháp phụ lục <strong><t t-out="object.name"/></strong> kèm theo Hợp đồng <strong><t t-out="object.contract_id.name"/></strong> để Quý công ty xem xét.</p>
            <p>Vui lòng liên hệ lại nếu có điều chỉnh.</p>
            <p>Trân trọng,<br/><t t-out="object.contract_id.user_id.name"/></p>
        </field>
        <field name="report_template_ids" eval="[(4, ref('att_contract_management.action_report_att_appendix'))]"/>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="email_template_contract_expiring" model="mail.template">
        <field name="name">Hợp đồng: Sắp hết hạn</field>
        <field name="model_id" ref="model_att_contract"/>
        <field name="subject">Thông báo: Hợp đồng {{ object.name }} sắp hết hạn</field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="email_cc">{{ object.user_id.email }}</field>
        <field name="body_html" type="html">
            <p>Kính gửi <t t-out="object.partner_id.name"/>,</p>
            <p>Hợp đồng <strong><t t-out="object.name"/></strong> sẽ hết hạn vào ngày <strong><t t-out="object.expired_date"/></strong>.</p>
            <p>Vui lòng liên hệ để gia hạn hoặc ký hợp đồng mới nếu cần.</p>
            <p>Trân trọng,<br/><t t-out="object.user_id.name"/></p>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>
