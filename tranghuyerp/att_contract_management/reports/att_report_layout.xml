<odoo>
    <!-- Layout header/footer Trang Huy — thay web.external_layout cho MỌI
         report chứng từ (báo giá, phụ lục, HĐNT, đơn hàng...). Report nào
         muốn dùng chỉ cần đổi t-call="web.external_layout" thành
         t-call="att_contract_management.att_external_layout".
         Header: dải logo + chứng chỉ (trái) — khối thông tin công ty (phải),
         theo đúng mẫu nhận diện Trang Huy Logistics. Ảnh nào chưa upload
         trong Cấu hình công ty > Chữ ký & In ấn thì tự ẩn, không vỡ layout. -->
    <template id="att_external_layout">
        <t t-set="company" t-value="(doc and doc.company_id) or (o and o.company_id) or res_company"/>

        <!-- CSS nằm NGAY TRONG từng mảnh (header/article/footer) — 3 mảnh
             này bị Odoo TÁCH thành 3 tài liệu HTML riêng khi xuất PDF
             (xem ir_actions_report._prepare_html), style khai ở ngoài
             template (file .scss của module) chỉ chắc ăn với mảnh article,
             nên nhúng trực tiếp ở đây để cả 3 mảnh đều nhận đúng font. -->
        <style>
            .header, .footer, .article {
                font-family: "Times New Roman", Times, "Liberation Serif", serif !important;
            }
            .article { font-size: 13px; }
        </style>

        <div class="header att_report_header">
            <div class="row align-items-center">
                <div class="col-7">
                    <t t-set="header_logo" t-value="company.report_header_logo or company.logo"/>
                    <img t-if="header_logo" t-att-src="image_data_uri(header_logo)"
                         style="max-height: 46px; margin-right: 8px;" alt="Logo"/>
                    <img t-if="company.report_cert_iso9001"
                         t-att-src="image_data_uri(company.report_cert_iso9001)"
                         style="max-height: 46px; margin-right: 8px;" alt="ISO 9001"/>
                    <img t-if="company.report_cert_iso27001"
                         t-att-src="image_data_uri(company.report_cert_iso27001)"
                         style="max-height: 46px; margin-right: 8px;" alt="ISO 27001"/>
                    <img t-if="company.report_cert_esg"
                         t-att-src="image_data_uri(company.report_cert_esg)"
                         style="max-height: 46px;" alt="ESG"/>
                </div>
                <div class="col-5" style="font-size: 11px; line-height: 1.45;">
                    <strong style="font-size: 13px;" t-out="(company.name or '').upper()"/>
                    <div t-if="company.partner_id.contact_address_inline">
                        Trụ sở chính: <span t-out="company.partner_id.contact_address_inline"/>
                    </div>
                    <div t-if="company.report_office_address">
                        VPGD: <span t-field="company.report_office_address"/>
                    </div>
                    <div>
                        <t t-if="company.vat">Mã số thuế: <span t-field="company.vat"/></t>
                        <t t-if="company.email"> · Email: <span t-field="company.email"/></t>
                    </div>
                    <div t-if="company.report_hotline">
                        Hotline: <span t-field="company.report_hotline"/>
                    </div>
                </div>
            </div>
            <div style="border-bottom: 2px solid #1f3a5f; margin-top: 6px;"/>
        </div>

        <!-- Khoảng cách header–body: margin-top thật (chừa header không đè
             lên body) do report.paperformat (data/report_paperformat.xml)
             lo — CSS ở đây chỉ để chắc thêm khi xem ở màn hình/HTML preview
             (report_type != 'pdf', paperformat không có tác dụng ở đó). -->
        <div class="article" t-att-data-oe-model="doc and doc._name"
             t-att-data-oe-id="doc and doc.id"
             t-attf-style="{{report_type != 'pdf' and 'margin-top: 18px;'}}">
            <t t-out="0"/>
        </div>

        <div class="footer" style="font-size: 10px; border-top: 1px solid #1f3a5f; padding-top: 4px;">
            <div class="row">
                <div class="col-8">
                    <strong t-out="company.name"/>
                    <t t-if="company.report_hotline"> · Hotline: <span t-field="company.report_hotline"/></t>
                    <t t-if="company.email"> · <span t-field="company.email"/></t>
                    <t t-if="company.website"> · <span t-field="company.website"/></t>
                </div>
                <div class="col-4 text-end">
                    Trang <span class="page"/> / <span class="topage"/>
                </div>
            </div>
        </div>
    </template>
</odoo>
