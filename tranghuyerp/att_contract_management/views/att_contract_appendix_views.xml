<odoo>
    <record id="view_att_appendix_form" model="ir.ui.view">
        <field name="name">att.contract.appendix.form</field>
        <field name="model">att.contract.appendix</field>
        <field name="arch" type="xml">
            <form string="Phụ lục hợp đồng">
                <header>
                    <button name="action_load_source_lines" string="Nạp dòng từ báo giá"
                            type="object" invisible="state != 'draft'"/>
                    <button name="action_confirm" string="Xác nhận"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"
                            groups="att_contract_management.group_att_qc_manager"/>
                    <button name="action_create_sale_order" string="Sinh SO thực thi"
                            type="object" class="btn-primary"
                            invisible="state not in ('confirmed', 'done') or appendix_type != 'sale'"/>
                    <button name="action_cancel" string="Huỷ" type="object"
                            invisible="state in ('cancelled', 'superseded')"/>
                    <button name="%(action_att_send_document_wizard)d"
                            string="Gửi cho đối tác" type="action"
                            context="{'default_res_model': 'att.contract.appendix', 'default_res_id': id}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <field name="att_can_edit" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_orders" type="object"
                                class="oe_stat_button" icon="fa-list"
                                invisible="state not in ('confirmed', 'done')">
                            <div class="o_stat_info">
                                <span class="o_stat_text">SO thực thi</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="contract_id" readonly="state != 'draft'"/>
                            <field name="appendix_type"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="effective_date" readonly="state != 'draft'"/>
                            <field name="source_sale_order_id"
                                   readonly="state != 'draft'"
                                   invisible="appendix_type != 'sale'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Người ký">
                        <group>
                            <field name="partner_signer_ids" widget="many2many_tags"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="company_signer_ids" widget="many2many_tags"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Dòng phụ lục" name="lines">
                            <field name="appendix_line_ids"
                                   readonly="state != 'draft'"
                                   widget="section_and_note_one2many">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_line" string="Thêm dòng"/>
                                        <create name="add_section" string="Thêm nhóm"
                                                context="{'default_display_type': 'line_section'}"/>
                                        <create name="add_note" string="Thêm ghi chú"
                                                context="{'default_display_type': 'line_note'}"/>
                                    </control>
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_type" column_invisible="1"/>
                                    <field name="name" widget="section_and_note_text"/>
                                    <field name="product_id" optional="hide" string="Dịch vụ"/>
                                    <field name="uom_id" optional="show"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="tax_ids" widget="many2many_tags"
                                           optional="show"/>
                                    <field name="price_subtotal" widget="monetary"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer">
                                <field name="amount_untaxed" widget="monetary"/>
                                <field name="amount_total" widget="monetary"
                                       class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_att_appendix_list" model="ir.ui.view">
        <field name="name">att.contract.appendix.list</field>
        <field name="model">att.contract.appendix</field>
        <field name="arch" type="xml">
            <list string="Phụ lục"
                  decoration-muted="state in ('cancelled', 'superseded')">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="partner_id"/>
                <field name="appendix_type" optional="show"/>
                <field name="effective_date"/>
                <field name="amount_total" sum="Tổng"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('confirmed', 'done')"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_att_appendix_search" model="ir.ui.view">
        <field name="name">att.contract.appendix.search</field>
        <field name="model">att.contract.appendix</field>
        <field name="arch" type="xml">
            <search string="Phụ lục">
                <field name="name"/>
                <field name="contract_id"/>
                <field name="partner_id"/>
<!--                <filter name="active_price" string="Giá đang hiệu lực"-->
<!--                        domain="[('state', 'in', ('confirmed', 'done'))]"/>-->
<!--                <group expand="0" string="Nhóm theo">-->
<!--                    <filter name="group_contract" string="Hợp đồng"-->
<!--                            context="{'group_by': 'contract_id'}"/>-->
<!--                    <filter name="group_state" string="Trạng thái"-->
<!--                            context="{'group_by': 'state'}"/>-->
<!--                </group>-->
            </search>
        </field>
    </record>

    <!-- Phụ lục hợp đồng mua — menu bên trong ứng dụng Purchase
         (root menu_att_purchase_contract_root định nghĩa ở att_contract_views.xml,
         file đó load TRƯỚC file này trong manifest nên ref được) -->
    <record id="action_att_appendix" model="ir.actions.act_window">
        <field name="name">Phụ lục hợp đồng</field>
        <field name="res_model">att.contract.appendix</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_att_appendix_search"/>
        <field name="domain">[('appendix_type', '=', 'purchase')]</field>
        <field name="context">{'default_contract_type': 'purchase'}</field>
        <field name="group_ids" eval="[(4, ref('att_contract_management.group_att_qc_user'))]"/>
    </record>

    <menuitem id="menu_att_appendix"
              name="Phụ lục hợp đồng"
              parent="menu_att_purchase_contract_root"
              action="action_att_appendix"
              sequence="20"
              groups="att_contract_management.group_att_qc_user"/>
</odoo>