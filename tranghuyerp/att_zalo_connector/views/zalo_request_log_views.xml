<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_zalo_request_log" model="ir.actions.act_window">
        <field name="name">Request Logs</field>
        <field name="res_model">att.zalo.request.log</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem
        id="menu_zalo_request_log"
        name="Request Logs"
        parent="menu_zalo_services_technical_root"
        action="action_zalo_request_log"
        sequence="10"
        groups="base.group_system"
    />
    <record id="view_zalo_request_log_search" model="ir.ui.view">
        <field name="name">zalo.request.log.search</field>
        <field name="model">att.zalo.request.log</field>
        <field name="arch" type="xml">
            <search string="Search Zalo Logs">
                <field name="name"/>
                <field name="endpoint"/>
                <field name="zalo_event_name"/>
                <field name="zalo_user_id"/>
                <field name="message_id"/>

<!--                <filter name="filter_inbound" string="Inbound" domain="[('direction','=','inbound')]"/>-->
<!--                <filter name="filter_outbound" string="Outbound" domain="[('direction','=','outbound')]"/>-->
<!--                <filter name="filter_webhook" string="Webhook" domain="[('is_webhook','=',True)]"/>-->
<!--                <filter name="filter_error" string="Errors" domain="[('state','=','error')]"/>-->

<!--                <group expand="0" string="Group By">-->
<!--                    <filter name="group_direction" string="Direction" context="{'group_by':'direction'}"/>-->
<!--                    <filter name="group_state" string="State" context="{'group_by':'state'}"/>-->
<!--                    <filter name="group_service_type" string="Service Type" context="{'group_by':'service_type'}"/>-->
<!--                    <filter name="group_event" string="Event" context="{'group_by':'zalo_event_name'}"/>-->
<!--                </group>-->
            </search>
        </field>
    </record>

    <record id="view_zalo_request_log_list" model="ir.ui.view">
        <field name="name">zalo.request.log.list</field>
        <field name="model">att.zalo.request.log</field>
        <field name="arch" type="xml">
            <list string="Zalo Request Logs" create="false" edit="false">
                <field name="create_date"/>
                <field name="name"/>
                <field name="service_type"/>
                <field name="direction" widget="badge"/>
                <field name="is_webhook"/>
                <field name="http_method"/>
                <field name="endpoint"/>
                <field name="zalo_event_name"/>
                <field name="response_code"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="view_zalo_request_log_form" model="ir.ui.view">
        <field name="name">zalo.request.log.form</field>
        <field name="model">att.zalo.request.log</field>
        <field name="arch" type="xml">
            <form string="Zalo Request Log" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Request">
                            <field name="config_id"/>
                            <field name="service_type"/>
                            <field name="direction"/>
                            <field name="is_webhook"/>
                            <field name="http_method"/>
                            <field name="endpoint"/>
                        </group>

                        <group string="Status">
                            <field name="state"/>
                            <field name="response_code" groups="base.group_no_one"/>
                            <field name="zalo_event_name"/>
                            <field name="zalo_user_id" groups="base.group_no_one"/>
                            <field name="message_id" groups="base.group_no_one"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Request" groups="base.group_no_one">
                            <group>
                                <field name="request_headers" widget="text" nolabel="1" />
                                <field name="request_body" widget="text" nolabel="1" />
                            </group>
                        </page>

                        <page string="Response" groups="base.group_no_one">
                            <group>
                                <field name="response_headers" widget="text" nolabel="1" />
                                <field name="response_body" widget="text" nolabel="1"/>
                            </group>
                        </page>

                        <page string="Error" groups="base.group_no_one">
                            <field name="error_message" widget="text" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>