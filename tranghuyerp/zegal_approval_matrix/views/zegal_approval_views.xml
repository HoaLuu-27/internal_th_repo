<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_zegal_approval_request" model="ir.sequence">
        <field name="name">Zegal Approval Request</field><field name="code">zegal.approval.request</field><field name="prefix">APR/%(year)s/</field><field name="padding">5</field>
    </record>
    <record id="view_zegal_approval_rule_list" model="ir.ui.view"><field name="name">zegal.approval.rule.list</field><field name="model">zegal.approval.rule</field><field name="arch" type="xml"><list><field name="name"/><field name="document_type"/><field name="minimum_amount"/><field name="maximum_amount"/><field name="approver_group_id"/><field name="active"/></list></field></record>
    <record id="view_zegal_approval_rule_form" model="ir.ui.view"><field name="name">zegal.approval.rule.form</field><field name="model">zegal.approval.rule</field><field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="active"/><field name="document_type"/><field name="company_id"/><field name="minimum_amount"/><field name="maximum_amount"/><field name="approver_group_id"/></group></sheet></form></field></record>
    <record id="view_zegal_approval_request_form" model="ir.ui.view"><field name="name">zegal.approval.request.form</field><field name="model">zegal.approval.request</field><field name="arch" type="xml"><form><header><button name="action_submit" type="object" string="Submit" invisible="state != 'draft'"/><button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="state != 'pending'"/><button name="action_reject" type="object" string="Reject" invisible="state != 'pending'"/><field name="state" widget="statusbar"/></header><sheet><group><group><field name="name"/><field name="document_type"/><field name="sale_order_id" invisible="document_type != 'sale'"/><field name="purchase_order_id" invisible="document_type != 'purchase'"/></group><group><field name="amount"/><field name="rule_id"/><field name="approver_group_id"/><field name="requester_id"/><field name="approver_id"/></group></group><group><field name="reason"/><field name="decision_note"/></group></sheet><chatter/></form></field></record>
    <record id="action_zegal_approval_request" model="ir.actions.act_window"><field name="name">Approval Requests</field><field name="res_model">zegal.approval.request</field><field name="view_mode">list,form</field></record>
    <record id="action_zegal_approval_rule" model="ir.actions.act_window"><field name="name">Approval Rules</field><field name="res_model">zegal.approval.rule</field><field name="view_mode">list,form</field></record>
    <menuitem id="menu_zegal_approval_root" name="Zegal Approvals" sequence="85"/>
    <menuitem id="menu_zegal_approval_requests" name="Requests" parent="menu_zegal_approval_root" action="action_zegal_approval_request"/>
    <menuitem id="menu_zegal_approval_rules" name="Rules" parent="menu_zegal_approval_root" action="action_zegal_approval_rule" groups="base.group_system" sequence="90"/>
</odoo>
